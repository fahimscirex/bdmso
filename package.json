{
  "name": "bdmso-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BdMSO static marketing site prepared for Cloudflare Pages and Workers with D1.",
  "scripts": {
    "dev:local": "npx live-server public --port=3000",
    "build": "node scripts/build.mjs",
    "build:apps": "pnpm -r build",
    "build:all": "npm run build && npm run build:apps",
    "clean": "rm -rf dist apps/*/dist",
    "posts:watch": "node scripts/build.mjs --watch",
    "cf:dev": "node scripts/dev.mjs",
    "dev:admin": "node scripts/dev-admin.mjs",
    "dev:guardian": "node scripts/dev-guardian.mjs",
    "preview": "npm run build:all && wrangler dev --config wrangler.prod.toml",
    "cf:deploy": "npm run build:all && wrangler deploy --config wrangler.prod.toml",
    "cf:d1:init": "wrangler d1 execute bdmso --local --file=./db/schema.sql",
    "cf:d1:init:prod": "wrangler d1 execute bdmso --file=./db/schema.sql",
    "admin:create": "node scripts/create-admin.mjs",
    "seed:registrations": "node scripts/seed-registrations.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hono": "^4.12.19"
  }
}
