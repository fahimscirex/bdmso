{
  "name": "bdmso-site",
  "version": "1.0.0",
  "private": true,
  "description": "BdMSO static marketing site prepared for Cloudflare Pages and Workers with D1.",
  "scripts": {
    "dev:local": "npx live-server public --port=3000",
    "build": "node scripts/build.mjs",
    "clean": "rm -rf dist",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:d1:init": "wrangler d1 execute bdmso --local --file=./schema.sql"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
"wrangler": "^4.13.2"
  }
}
