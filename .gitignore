# Dependencies
node_modules/

# Build output
dist/
# Per-post HTML is generated from public/posts/*.md by scripts/build.mjs
public/posts/*.html
# robots.txt + sitemap.xml are generated by scripts/build.mjs (also in dist/)
public/robots.txt
public/sitemap.xml

# Cloudflare Workers
.wrangler/
.dev.vars

# Environment
.env
.env.*
!.env.example
*.local

# Secrets / credentials (defensive — never commit private keys or certs)
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
# Bare filenames seen during Cloudflare Origin TLS download
/key
/origin

# Python virtualenv
.venv/
venv/
__pycache__/
*.pyc

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local agent state (user-specific; .codesight/ is project context - keep tracked)
.claude/
AGENTS.md
codex.md
.cursorrules

# Local notes
notes

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# Local tooling state
.commandcode/

# File-manager image metadata sidecars (Dolphin/Nautilus)
.comments/
