# Dependencies
node_modules/

# Build output
dist/
# Per-post HTML is generated from public/posts/*.md by scripts/build.mjs
public/posts/*.html
# robots.txt + sitemap.xml are generated by scripts/build.mjs (also in dist/)
public/robots.txt
public/sitemap.xml

# Cloudflare Workers
.wrangler/
.dev.vars

# Environment
.env
.env.*
!.env.example
*.local

# Secrets / credentials (defensive — never commit private keys or certs)
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
# Bare filenames seen during Cloudflare Origin TLS download
/key
/origin

# Python virtualenv
.venv/
venv/
__pycache__/
*.pyc

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI-assistant / external tooling files - never committed. .codesight/
# is the only external project context kept tracked (and only while it
# carries no sensitive data).
.claude/
CLAUDE.md
CLAUDE.original.md
AGENTS.md
codex.md
.cursorrules
SEO-AUDIT.md
DASHBOARD-PLAN.md

# Local notes
notes

# Root-level source PDFs are working docs - never commit them.
# Published copies belong in public/downloads/.
/*.pdf

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# Local tooling state
.commandcode/

# File-manager image metadata sidecars (Dolphin/Nautilus)
.comments/

# TypeScript incremental build artifacts
*.tsbuildinfo
tsconfig.tsbuildinfo
# Personal Wrangler overrides (e.g. wrangler.local.toml for a contributor
# pointing at their own D1/R2). The canonical wrangler.toml IS committed
# and carries both the default (local dev) and [env.production] config.
wrangler.local.toml
!wrangler.example.toml

# DB seeds with real coupon codes / internal data. The .example.sql
# files at the same path show the structure with placeholder codes
# so contributors know how to seed without leaking values.
db/seed-prod.sql
db/seed-dev.sql
