---
// Shared shell for every static page. Replaces the per-page <head> boilerplate
// and the build.mjs SEO/FONTS injection: SEO is now prop-driven and rendered
// here directly. Header/Footer are server-rendered Astro components; their
// interactive + session-aware bits live in Header.astro's client script. The
// page-visibility toggle and dropdown-enhancer loader (previously in site.js)
// are inlined at the end of <body>.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { optimizedAbsolute, optimizedDimensions } from "../lib/ogImage";

interface Props {
  title: string;
  description?: string;
  page?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  articlePublished?: string;
  articleAuthor?: string;
  jsonLd?: Record<string, unknown>[];
  robots?: string;
}
const {
  title,
  description = "",
  page = "",
  canonical = Astro.url.href,
  image = "https://bdmso.org/images/logo.webp",
  imageAlt,
  ogType = "website",
  articlePublished,
  articleAuthor,
  jsonLd = [],
  robots,
} = Astro.props;

const ogImage = await optimizedAbsolute(image);
const ogImageDims = await optimizedDimensions(image);
const ogImageAlt = imageAlt ?? title;

const FONT_HREF =
  "https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap";
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Meta Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init','2031727993749391');fbq('track','PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt=""
      src="https://www.facebook.com/tr?id=2031727993749391&ev=PageView&noscript=1"/></noscript>
    <!-- End Meta Pixel -->
    <!-- First-touch ad attribution: stash fbclid / utm_* so a registration started
         on another page can still be tied back to the ad click that landed here. -->
    <script is:inline>
      try {
        if (!localStorage.getItem('bdmso_attribution')) {
          var p = new URLSearchParams(location.search), d = {}, fb = p.get('fbclid');
          if (fb) d.fbclid = fb;
          ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach(function(k){var v=p.get(k);if(v)d[k]=v;});
          if (Object.keys(d).length) { d.landing = location.pathname; d.ts = new Date().toISOString(); localStorage.setItem('bdmso_attribution', JSON.stringify(d)); }
        }
      } catch (e) {}
    </script>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="BdMSO" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    {ogImageDims && <meta property="og:image:width" content={String(ogImageDims.width)} />}
    {ogImageDims && <meta property="og:image:height" content={String(ogImageDims.height)} />}
    <meta property="og:image:alt" content={ogImageAlt} />
    {articlePublished && <meta property="article:published_time" content={articlePublished} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="theme-color" content="#0b1b3f" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="BdMSO Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href={FONT_HREF}
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href={FONT_HREF} /></noscript>
    <link rel="preload" as="style" href="/css/styles.css" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="/css/styles.css" /></noscript>
    <style is:global>
      /* Skip-to-content link: visually hidden until focused (WCAG 2.4.1). */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 1000;
        padding: 10px 16px;
        background: var(--navy-900, #0b1b3f);
        color: #fff;
        font-weight: 700;
        border-radius: 0 0 8px 0;
        text-decoration: none;
      }
      .skip-link:focus {
        left: 0;
        outline: 2px solid var(--gold-500, #f5c518);
        outline-offset: 2px;
      }
      /* First global visible-focus affordance (WCAG 2.4.7). Additive: targets
         :focus-visible so it does not fight inputs that use box-shadow rings. */
      :focus-visible {
        outline: 2px solid var(--navy-700, #1c3a7a);
        outline-offset: 2px;
      }
      .bdsel-trigger:focus-visible {
        outline: 2px solid var(--navy-700, #1c3a7a);
        outline-offset: 2px;
      }
    </style>
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema).replace(/</g, "\\u003c")} />
    ))}
    <slot name="head" />
  </head>
  <body data-page={page}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header page={page} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // Pause decorative ambient animations while the tab is backgrounded.
      const syncVisibility = () =>
        document.documentElement.toggleAttribute("data-page-hidden", document.visibilityState === "hidden");
      document.addEventListener("visibilitychange", syncVisibility);
      syncVisibility();

      // Lazy-load the custom-dropdown enhancer (self-skips if nothing to enhance).
      if (!document.querySelector("script[data-bdsel-loader]")) {
        const s = document.createElement("script");
        s.src = "/js/select-enhance.js";
        s.defer = true;
        s.setAttribute("data-bdsel-loader", "1");
        document.head.appendChild(s);
      }
    </script>
  </body>
</html>
