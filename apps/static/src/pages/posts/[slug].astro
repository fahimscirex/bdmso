---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import Img from "../../components/Img.astro";
import { relatedTo } from "../../lib/related.js";
import { optimizedAbsolute } from "../../lib/ogImage";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const url = `https://bdmso.org/posts/${data.slug}`;
const image = data.image
  ? (data.image.startsWith("http") ? data.image : `https://bdmso.org/${data.image.replace(/^\//, "")}`)
  : "https://bdmso.org/images/group-winner.webp";
const metaDesc = data.description || data.excerpt;
const published = data.date.toISOString().slice(0, 10);
// dateModified falls back to datePublished until a post is actually revised
// (the optional `updated` frontmatter field, absent on most posts).
const modified = data.updated ? data.updated.toISOString().slice(0, 10) : published;
const dateFmt = data.date.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
// Crawler-facing JSON-LD images point at the optimized build assets.
const imageAbs = await optimizedAbsolute(image);
const logoAbs = await optimizedAbsolute("https://bdmso.org/images/logo.webp");

// Related programs: keyword overlap between this post and the program catalogue
// (neither has explicit tags). Only strong matches link - see lib/related.js.
const relatedPrograms = relatedTo(
  { title: data.title, slug: data.slug },
  (await getCollection("programs"))
    .filter((pr) => !pr.data.hidden)
    .map((pr) => ({ title: pr.data.title, slug: pr.id, url: `/programs/${pr.id}`, desc: pr.data.tagline })),
);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: metaDesc,
    datePublished: published,
    dateModified: modified,
    author: { "@type": "Person", name: data.author },
    image: imageAbs,
    publisher: {
      "@type": "Organization",
      name: "BdMSO",
      logo: { "@type": "ImageObject", url: logoAbs },
    },
    mainEntityOfPage: url,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://bdmso.org/" },
      { "@type": "ListItem", position: 2, name: "Blog", item: "https://bdmso.org/blog" },
      { "@type": "ListItem", position: 3, name: data.title, item: url },
    ],
  },
];
---

<BaseLayout
  title={`${data.title} - BdMSO`}
  description={metaDesc}
  page="blog"
  canonical={url}
  image={image}
  ogType="article"
  articlePublished={published}
  articleAuthor={data.author}
  jsonLd={jsonLd}
>
  <style is:global slot="head">
    .post-hero { background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%); position: relative; overflow: hidden; padding: 72px 0 0; }
    .post-hero::before { content: ""; position: absolute; inset: 0; background: radial-gradient(600px 280px at 50% 100%, var(--glow-gold-sm), transparent 60%); }
    .post-hero .container { position: relative; z-index: 1; text-align: center; display: flex; flex-direction: column; align-items: center; }
    .post-meta-bar { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
    .post-meta-bar .sep { display: none; }
    @media (min-width: 540px) { .post-meta-bar .sep { display: inline; } }
    /* Category as an editorial label (no pill) so it reads as a peer of the
       date/author rather than a mismatched solid chip. Hierarchy comes from
       the gold accent + weight + tracking, not a container. */
    .post-meta-bar .eyebrow { margin: 0; padding: 0; background: none; border: none; border-radius: 0; color: var(--gold-on-dark); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; }
    .post-meta-bar .eyebrow::before { display: none; }
    .post-meta-bar .sep { color: rgba(255,255,255,0.4); }
    .post-meta-bar .date, .post-meta-bar .author { font-size: 13px; color: var(--on-dark-3); }
    .post-title { color: white; font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.15; margin: 0 0 20px; max-width: 760px; }
    .post-excerpt { color: rgba(255,255,255,0.65); font-size: 1.05rem; max-width: 640px; margin: 0 0 40px; }
    .post-cover { width: 100%; max-width: 900px; margin: 0 auto; border-radius: var(--r-xl) var(--r-xl) 0 0; overflow: hidden; aspect-ratio: 16/7; position: relative; }
    .post-cover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .post-cover .ph { position: absolute; inset: 0; border-radius: 0; border: none; }
    .post-body { max-width: 720px; margin: 0 auto; padding: 56px 24px 96px; }
    .post-body h2 { font-size: 1.45rem; margin: 2em 0 0.5em; color: var(--navy-900); }
    .post-body h3 { font-size: 1.2rem; margin: 1.8em 0 0.4em; color: var(--navy-900); }
    .post-body h4 { font-size: 1rem; margin: 1.6em 0 0.3em; color: var(--navy-900); }
    .post-body p  { line-height: 1.8; color: var(--ink-1); margin: 0 0 1.2em; }
    .post-body ul, .post-body ol { padding-left: 22px; margin: 0 0 1.2em; }
    .post-body li { line-height: 1.7; color: var(--ink-1); margin-bottom: 4px; }
    .post-body strong { color: var(--navy-900); }
    .post-body a { color: var(--navy-700); text-decoration: underline; }
    .post-body blockquote { border-left: 3px solid var(--navy-200); margin: 1.5em 0; padding: 12px 20px; background: var(--navy-50); border-radius: 0 var(--r) var(--r) 0; }
    .post-body blockquote p { margin: 0; color: var(--ink-2); font-style: italic; }
    .post-body hr { border: none; border-top: 1px solid var(--line); margin: 2.5em 0; }
    .post-body code { font-family: var(--font-mono); font-size: 0.88em; background: var(--navy-50); padding: 2px 6px; border-radius: 4px; }
    .post-body figure { margin: 2em 0; }
    .post-body figure img { width: 100%; border-radius: var(--r-lg); }
    .post-body figure figcaption { font-size: 13px; color: var(--ink-3); text-align: center; margin-top: 8px; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.6); margin-bottom: 28px; text-decoration: none; align-self: flex-start; transition: color 0.15s; }
    .back-link:hover { color: white; }
    .back-link::before { content: "←"; }
    @media (max-width: 539px) {
      .post-hero { padding: 40px 0 0; }
      .post-title { font-size: 1.55rem; margin-bottom: 24px; }
      .post-excerpt { display: none; }
      /* Stack on mobile: category label on its own line, then a clean
         "date · author" byline below (author stays visible). */
      .post-meta-bar { gap: 6px 8px; margin-bottom: 16px; }
      .post-meta-bar .eyebrow { flex-basis: 100%; justify-content: center; }
      .post-meta-bar .sep { display: inline; }
      .post-meta-bar .eyebrow + .sep { display: none; }
      .post-body { padding: 32px 20px 64px; }
    }
  </style>

    <section class="post-hero">
      <div class="container">
        <a class="back-link" href="/blog">Back to Blog</a>
        <div class="post-meta-bar">
          {data.category && <span class="eyebrow">{data.category}</span>}
          {data.date && <><span class="sep">·</span><span class="date">{dateFmt}</span></>}
          {data.author && <><span class="sep">·</span><span class="author">{data.author}</span></>}
        </div>
        <h1 class="post-title">{data.title}</h1>
        {data.excerpt && <p class="post-excerpt">{data.excerpt}</p>}
      </div>
      {data.image && (
        <div class="post-cover">
          <Img src={`/${data.image.replace(/^\//, "")}`} alt={data.title} widths={[400, 900]} sizes="(max-width: 900px) 100vw, 900px" loading="eager" fetchpriority="high" />
        </div>
      )}
    </section>

    <div class="post-body">
      <Content />
    </div>

    <RelatedContent
      heading="Related programs"
      items={relatedPrograms.map((r) => ({ kicker: "Program", title: r.title, desc: r.desc, url: r.url }))}
    />
</BaseLayout>
