---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const title = "BdMSO Results 2026 and 2025 - Olympiad Medal Winners";
const description =
  "BdMSO Olympiad results - gold, silver, and bronze medalists in Mathematics and Science across the National Round (2026 and 2025 archives).";

// Medalists come from D1 (edited in the admin dashboard), materialized to the
// medalists content collection. We always show the current year's tab (even
// before its results are announced) plus every year that has published winners.
const all = await getCollection("medalists");
const currentYear = String(new Date().getFullYear());
const years = [...new Set([currentYear, ...all.map((m) => m.data.year)])].sort((a, b) => b.localeCompare(a));

const CATEGORY_ORDER = ["Mathematics", "Science"];
const MEDAL_ORDER = ["gold", "silver", "bronze"] as const;
const MEDAL_LABEL: Record<string, string> = { gold: "Gold Medal", silver: "Silver Medal", bronze: "Bronze Medal" };
const MEDAL_DISC: Record<string, string> = { gold: "G", silver: "S", bronze: "B" };

const categoriesFor = (year: string) =>
  [...new Set(all.filter((m) => m.data.year === year).map((m) => m.data.category))].sort((a, b) => {
    const rank = (c: string) => (CATEGORY_ORDER.indexOf(c) === -1 ? 99 : CATEGORY_ORDER.indexOf(c));
    return rank(a) - rank(b) || a.localeCompare(b);
  });
const winnersFor = (year: string, category: string, medal: string) =>
  all.filter((m) => m.data.year === year && m.data.category === category && m.data.medal === medal);

// Structured data: an ItemList of the most recent published medalists, each a
// Person with their award - lets search engines surface the winners.
const latestWithWinners = years.find((y) => all.some((m) => m.data.year === y));
const medalistRows = latestWithWinners ? all.filter((m) => m.data.year === latestWithWinners) : [];
const resultsSchema = medalistRows.length
  ? [{
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: `BdMSO ${latestWithWinners} Medal Winners`,
      itemListElement: medalistRows.map((m, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: {
          "@type": "Person",
          name: m.data.name,
          ...(m.data.school ? { affiliation: { "@type": "Organization", name: m.data.school } } : {}),
          award: `${MEDAL_LABEL[m.data.medal] ?? m.data.medal} · ${m.data.category} (BdMSO ${latestWithWinners})`,
        },
      })),
    }]
  : [];
---

<BaseLayout
  title={title}
  description={description}
  page="results"
  canonical="https://bdmso.org/results"
  image="https://bdmso.org/images/group-winner.webp"
  jsonLd={resultsSchema}
>
  <style is:global slot="head">
    .page-head { background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%); color: white; padding: 80px 0 100px; position: relative; overflow: hidden; }
    .page-head::before { content:""; position:absolute; inset:0; background: radial-gradient(600px 300px at 50% 100%, var(--glow-gold-sm), transparent 60%); }
    .page-head .eyebrow { background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); margin-bottom: 18px; }
    .page-head h1 { color: white; max-width: 720px; margin: 0 0 12px; }
    .page-head p { color: var(--on-dark-2); max-width: 600px; margin: 0; font-size: 1.05rem; }

    .results-wrap { margin-top: -56px; position: relative; z-index: 2; padding-bottom: 96px; }

    .years { display: flex; gap: 6px; padding: 10px; background: white; border: 1px solid var(--line); border-radius: 14px; box-shadow: var(--shadow-sm); margin-bottom: 28px; overflow-x: auto; max-width: 100%; }
    .years button { padding: 9px 18px; font-weight: 600; font-size: 14px; color: var(--ink-2); border-radius: 10px; white-space: nowrap; flex-shrink: 0; }
    .years button.active { background: var(--navy-900); color: white; }
    .years button:hover:not(.active) { background: var(--navy-50); color: var(--navy-800); }

    .notice { background: var(--gold-100); border: 1px solid var(--notice-gold-bd); border-radius: 12px; padding: 12px 16px; margin-bottom: 28px; font-size: 13.5px; color: var(--icon-gold); display: flex; gap: 10px; align-items: flex-start; }

    .accordion { display: flex; flex-direction: column; gap: 14px; }
    .acc {
      background: white; border: 1px solid var(--line); border-radius: var(--r-lg); overflow: hidden;
    }
    .acc summary {
      list-style: none; cursor: pointer;
      padding: 22px 28px;
      display: flex; justify-content: space-between; align-items: center; gap: 16px;
      transition: background 0.2s;
    }
    .acc summary:hover { background: var(--bg-alt); }
    .acc summary::-webkit-details-marker { display: none; }
    .acc .title-wrap { display: flex; flex-direction: column; gap: 4px; }
    .acc .kind { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--navy-700); }
    .acc h2 { font-size: 1.3rem; font-family: var(--font-display); margin: 0; font-weight: 600; }
    .acc .chev { font-size: 20px; color: var(--ink-3); transition: transform 0.2s; }
    .acc[open] .chev { transform: rotate(180deg); }
    .acc .body { padding: 0 28px 28px; border-top: 1px solid var(--line-2); padding-top: 24px; }

    .medal-block { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
    @media (max-width: 900px) { .medal-block { grid-template-columns: 1fr; } }
    .medal-col h4 {
      font-family: var(--font-sans); font-size: 13px; text-transform: uppercase; letter-spacing: 0.14em;
      margin-bottom: 14px; display: flex; align-items: center; gap: 10px;
    }
    .medal-col h4 .disc { width: 22px; height: 22px; border-radius: 50%; display: grid; place-items: center; color: white; font-size: 12px; font-weight: 800; }
    .medal-col.gold h4 .disc { background: var(--gold-500); color: var(--navy-900); }
    .medal-col.silver h4 .disc { background: var(--medal-silver-alt); color: var(--navy-900); }
    .medal-col.bronze h4 .disc { background: var(--medal-bronze-alt); }
    .medal-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
    .medal-col li {
      padding: 10px 14px; background: var(--bg-alt); border-radius: 8px;
      font-size: 14px; color: var(--navy-900); font-weight: 500;
      display: flex; justify-content: space-between; gap: 8px;
    }
    .medal-col li .school { font-size: 12px; color: var(--ink-3); font-weight: 400; }

    .shortlist { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
    @media (max-width: 800px) { .shortlist { grid-template-columns: 1fr; } }
    .shortlist h4 {
      font-family: var(--font-sans); font-size: 13px; text-transform: uppercase; letter-spacing: 0.14em;
      margin-bottom: 14px; color: var(--navy-800);
    }
    .shortlist ol { margin: 0; padding-left: 20px; display: grid; gap: 6px; font-size: 14px; color: var(--navy-900); }
    .shortlist ol li { padding: 6px 0; border-bottom: 1px solid var(--line-2); }
    .shortlist ol li .s { color: var(--ink-3); font-size: 12px; }

    .logic-note {
      padding: 16px; background: var(--navy-50); border-radius: 10px; margin-top: 20px;
      font-size: 13.5px; color: var(--navy-800);
    }

    .delegation { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 900px) { .delegation { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 500px) { .delegation { grid-template-columns: 1fr; } }
    .deleg {
      padding: 16px; background: var(--bg-alt); border-radius: var(--r); text-align: center;
    }
    .deleg .ph { aspect-ratio: 1/1; border-radius: 50%; margin-bottom: 12px; font-size: 11px; }
    .deleg .n { font-weight: 700; color: var(--navy-900); font-size: 14px; }
    .deleg .r { font-size: 12px; color: var(--ink-3); margin-top: 2px; }
  </style>

  <main>
    <section class="page-head"><div class="container">
      <span class="eyebrow">Hall of Excellence</span>
      <h1>BdMSO Results &amp; Rankings</h1>
    </div></section>

    <section class="container results-wrap">
      <div class="years" role="tablist">
        {years.map((y, i) => (
          <button class={i === 0 ? "active" : ""} data-year={y}>{y}</button>
        ))}
      </div>

      <div class="notice">
        <span>ℹ️</span>
        <span>To protect our students, <strong>numerical scores are hidden</strong>. Medalists are listed in order of BdMSO ID.</span>
      </div>

      {years.map((y, i) => {
        const cats = categoriesFor(y);
        return (
          <div class="year-panel" data-year={y} hidden={i !== 0}>
            <div class="accordion">
              {cats.length === 0 ? (
                <details class="acc" open>
                  <summary>
                    <div class="title-wrap"><span class="kind">Olympiad</span><h2>Olympiad Results · {y}</h2></div>
                    <span class="chev">⌄</span>
                  </summary>
                  <div class="body">
                    <div style="padding:36px 20px; text-align:center; background:var(--bg-alt); border-radius:var(--r); border:1px dashed var(--line);">
                      <div style="font-size:40px; margin-bottom:10px;">🕒</div>
                      <h4 style="font-family:var(--font-display); color:var(--navy-900); margin-bottom:8px;">Results not yet announced</h4>
                      <p style="margin:0 auto; color:var(--ink-2); font-size:14px; max-width:480px;">Winners are published here within one week of the competition day.</p>
                    </div>
                  </div>
                </details>
              ) : cats.map((cat, ci) => (
                <details class="acc" open={ci === 0}>
                  <summary>
                    <div class="title-wrap"><span class="kind">Olympiad · {cat}</span><h2>BdMSO {y} · {cat} Winners</h2></div>
                    <span class="chev">⌄</span>
                  </summary>
                  <div class="body">
                    <div class="medal-block">
                      {MEDAL_ORDER.map((medal) => (
                        <div class={`medal-col ${medal}`}>
                          <h4><span class="disc">{MEDAL_DISC[medal]}</span>{MEDAL_LABEL[medal]}</h4>
                          <ul>
                            {winnersFor(y, cat, medal).map((w) => (
                              <li>{w.data.name} <span class="school">{w.data.school}</span></li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  </main>

  <script is:inline>
  document.querySelectorAll('.years button').forEach(b => b.addEventListener('click', () => {
    document.querySelectorAll('.years button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const yr = b.dataset.year;
    document.querySelectorAll('.year-panel').forEach(p => {
      p.hidden = p.dataset.year !== yr;
    });
  }));
  </script>
</BaseLayout>
