---
// Guardian sign-in + account recovery. Ported from public/login.html during the
// Astro cutover: BaseLayout supplies the server-rendered Header/Footer + SEO/fonts
// (replacing the old #site-header/#site-footer/site.js), and the vanilla module
// script is kept inline against the served /js/api.js.
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Log in - BdMSO"
  description="Log in to your BdMSO account to manage registrations and results."
  page="login"
  robots="noindex,follow"
  canonical="https://bdmso.org/login"
>
  <style is:global slot="head">
    .login-wrap {
      min-height: calc(100vh - 72px);
      display: flex; align-items: center; justify-content: center;
      padding: 48px 24px;
      background: var(--bg-alt);
    }
    .login-card {
      background: white; border: 1px solid var(--line);
      border-radius: var(--r-lg); padding: 40px;
      width: 100%; max-width: 440px;
      box-shadow: var(--shadow-sm);
    }
    .login-card .eyebrow { margin-bottom: 20px; }
    .login-card h2 { margin: 0 0 6px; }
    .login-card .sub { color: var(--ink-2); margin: 0 0 32px; font-size: 15px; }

    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .field label { font-size: 13px; font-weight: 600; color: var(--navy-900); }
    .field input {
      padding: 10px 14px; border: 1px solid var(--line);
      border-radius: var(--r); font-size: 15px;
      background: white; color: var(--ink-1);
      font-family: var(--font-sans); width: 100%; box-sizing: border-box;
    }
    .field input:focus { outline: none; border-color: var(--navy-700); box-shadow: 0 0 0 4px var(--focus-ring); }
    .pw-field { position: relative; }
    .pw-field input { padding-right: 44px; }
    .pw-eye {
      position: absolute; right: 0; top: 0; bottom: 0; width: 42px;
      display: flex; align-items: center; justify-content: center;
      background: transparent; border: none; cursor: pointer; color: var(--ink-3);
      padding: 0; border-radius: 0 var(--r) var(--r) 0;
    }
    .pw-eye:hover { color: var(--navy-900); }
    .pw-eye:focus-visible { outline: 2px solid var(--navy-700); outline-offset: -2px; }
    .pw-eye .eye-off { display: none; }
    .pw-eye[aria-pressed="true"] .eye-on  { display: none; }
    .pw-eye[aria-pressed="true"] .eye-off { display: block; }

    .error-msg {
      background: #fef2f2; border: 1px solid #fecaca;
      color: #dc2626; border-radius: var(--r);
      padding: 10px 14px; font-size: 14px; margin-bottom: 16px;
    }
    .login-submit { width: 100%; margin-top: 8px; justify-content: center; }
    .login-footer { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--line-2); text-align: center; font-size: 14px; color: var(--ink-3); }
    .login-footer a { color: var(--navy-700); font-weight: 600; }

    .forgot-link {
      background: none; border: none; padding: 8px 0;
      font: inherit; font-size: 13px; color: var(--navy-700);
      font-weight: 600; cursor: pointer; text-decoration: underline;
      text-underline-offset: 3px;
      transition: color var(--dur-ui) ease, transform var(--dur-press) var(--ease-out);
    }
    .forgot-link:hover { color: var(--navy-900); }
    .forgot-link:active { transform: scale(0.97); }

    .recover-tabs {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4px; padding: 4px; background: var(--bg-alt);
      border-radius: 10px; margin-bottom: 18px;
    }
    .recover-tab {
      padding: 8px 12px; border: none; background: transparent;
      font: inherit; font-size: 13.5px; font-weight: 600;
      color: var(--ink-2); cursor: pointer; border-radius: 7px;
      transition: background-color var(--dur-ui) ease, color var(--dur-ui) ease;
    }
    .recover-tab.is-active { background: white; color: var(--navy-900); box-shadow: 0 1px 2px rgba(15,23,42,0.06); }

    .recover-help { font-size: 13px; color: var(--ink-2); line-height: 1.5; margin: 0 0 14px; }
    .recover-result {
      margin-top: 14px; padding: 12px 14px;
      background: var(--bg-alt); border: 1px solid var(--line);
      border-radius: 10px; font-size: 13.5px;
    }
    .recover-result .label {
      display: block; font-size: 11px; font-weight: 700;
      color: var(--ink-3); text-transform: uppercase;
      letter-spacing: 0.08em; margin-bottom: 4px;
    }
    .recover-result .value { font-family: var(--font-mono); font-size: 14.5px; color: var(--navy-900); font-weight: 600; }
    .recover-result.ok { border-color: #bbe5cb; background: #f0faf3; }
    .recover-result.bad { border-color: #fecaca; background: #fef2f2; }
    .recover-result p { margin: 6px 0 0; color: var(--ink-2); }

    .recover-stuck {
      margin-top: 18px; padding-top: 16px;
      border-top: 1px solid var(--line-2);
      font-size: 13px; color: var(--ink-3); text-align: center;
    }
    .recover-stuck a { color: var(--navy-700); font-weight: 600; }

    .recover-back {
      background: none; border: none; padding: 0;
      font: inherit; font-size: 13px; color: var(--ink-3);
      cursor: pointer; margin-bottom: 16px;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .recover-back:hover { color: var(--navy-800); }
    .recover-back svg { width: 14px; height: 14px; }

    .field-prefixed {
      display: flex; align-items: stretch;
      border: 1px solid var(--line); border-radius: var(--r);
      overflow: hidden; background: white;
      transition: border-color var(--dur-ui) ease, box-shadow var(--dur-ui) ease;
    }
    .field-prefixed:focus-within { border-color: var(--navy-700); box-shadow: 0 0 0 4px var(--focus-ring); }
    .field-prefixed .prefix {
      display: inline-flex; align-items: center;
      padding: 0 12px; background: var(--bg-alt);
      border-right: 1px solid var(--line);
      font-family: var(--font-mono); font-size: 13.5px;
      font-weight: 600; color: var(--ink-2); user-select: none;
    }
    .field-prefixed input {
      flex: 1; min-width: 0; border: 0; background: transparent;
      padding: 10px 14px; font: inherit; font-size: 15px;
      font-family: var(--font-mono); color: var(--ink-1);
    }
    .field-prefixed input:focus { outline: none; box-shadow: none; }

    @media (max-width: 480px) { .login-card { padding: 28px 20px; } }
  </style>

    <div class="login-wrap">
      <div class="login-card">
        <!-- Sign-in view -->
        <div id="signin-view">
          <span class="eyebrow">BdMSO Portal</span>
          <h1 style="font-size:1.4rem; margin:0 0 6px;">Sign in to BdMSO</h1>
          <p class="sub">Sign in to view your child's registration and updates.</p>

          <form id="login-form" novalidate>
            <div class="field">
              <label for="login-email">Email address</label>
              <input type="email" id="login-email" name="email" placeholder="guardian@example.com" autocomplete="email" required />
            </div>
            <div class="field">
              <label for="login-password">Password</label>
              <div class="pw-field">
                <input type="password" id="login-password" name="password" placeholder="••••••••" autocomplete="current-password" required />
                <button type="button" class="pw-eye" aria-label="Show password" data-pw="login-password" tabindex="-1">
                  <svg class="eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </button>
              </div>
            </div>
            <div id="login-error" class="error-msg" hidden></div>
            <button type="submit" class="btn btn-primary login-submit">Sign in</button>
          </form>

          <p style="margin-top:14px; text-align:center;">
            <button type="button" class="forgot-link" id="open-recover">Forgot password or email?</button>
          </p>

          <div class="login-footer">
            Don't have an account? <a href="/registration">Register here</a>
          </div>
        </div>

        <!-- Recovery view -->
        <div id="recover-view" hidden>
          <button type="button" class="recover-back" id="recover-back" aria-label="Back to sign in">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Back to sign in
          </button>
          <h2 style="font-size:1.4rem; margin:0 0 6px;">Recover your account</h2>
          <p class="sub">Pick what you've forgotten - we'll guide you through.</p>

          <div class="recover-tabs" role="tablist">
            <button type="button" class="recover-tab is-active" data-tab="password" role="tab" aria-selected="true">Forgot password</button>
            <button type="button" class="recover-tab" data-tab="email" role="tab" aria-selected="false">Forgot email</button>
          </div>

          <div id="recover-password" class="recover-pane">
            <p class="recover-help">Enter your account email and we'll send a reset link.</p>
            <form id="forgot-password-form" novalidate>
              <div class="field">
                <label for="fp-email">Email address</label>
                <input type="email" id="fp-email" name="email" placeholder="guardian@example.com" autocomplete="email" required />
              </div>
              <div id="fp-error" class="error-msg" hidden></div>
              <button type="submit" class="btn btn-primary login-submit">Send reset link</button>
            </form>
            <div id="fp-result" class="recover-result ok" hidden>
              <span class="label">Sent</span>
              <p>If that email belongs to a BdMSO account, a reset link is on its way. The link expires in 1 hour. Check spam if you don't see it.</p>
            </div>
          </div>

          <div id="recover-email" class="recover-pane" hidden>
            <p class="recover-help">Enter your phone number <em>or</em> BdMSO ID - we'll show a partial match of your account email.</p>
            <form id="forgot-email-form" novalidate>
              <div class="field">
                <label for="fe-phone">Phone number</label>
                <input type="tel" id="fe-phone" name="phone" placeholder="01XXXXXXXXX" autocomplete="tel" />
              </div>
              <div style="text-align:center; font-size:12px; color:var(--ink-3); margin: 6px 0 10px;">— or —</div>
              <div class="field">
                <label for="fe-memberid">BdMSO ID</label>
                <div class="field-prefixed">
                  <span class="prefix" aria-hidden="true">BdMSO</span>
                  <input type="text" id="fe-memberid" name="memberId" placeholder="2604-001" inputmode="numeric" maxlength="8" />
                </div>
              </div>
              <div id="fe-error" class="error-msg" hidden></div>
              <button type="submit" class="btn btn-primary login-submit">Find my email</button>
            </form>
            <div id="fe-result-ok" class="recover-result ok" hidden>
              <span class="label">Account email</span>
              <div class="value" id="fe-result-email"></div>
              <p>Use the full address to sign in or to reset your password.</p>
            </div>
            <div id="fe-result-none" class="recover-result bad" hidden>
              <span class="label">No match</span>
              <p>We couldn't find an account with that phone or BdMSO ID. Try the other field, or email <a href="mailto:support@bdmso.org">support@bdmso.org</a>.</p>
            </div>
          </div>

          <div class="recover-stuck">
            Don't remember either? Email
            <a href="mailto:support@bdmso.org?subject=Account%20recovery">support@bdmso.org</a>
            and we'll help you in.
          </div>
        </div>
      </div>
    </div>

  <script is:inline type="module">
    import { postJson } from '/js/api.js';

    // Redirect if already logged in (no redirect param means normal dashboard flow)
    const loginRedirectTo = (() => {
      try {
        const r = new URL(window.location.href).searchParams.get('redirect');
        return r && r.startsWith('/') ? r : null;
      } catch { return null; }
    })();
    if (!loginRedirectTo) {
      try {
        if (JSON.parse(localStorage.getItem('bdmso_user'))) window.location.replace('/dashboard');
      } catch {}
    }

    // Password show/hide toggles
    document.querySelectorAll('.pw-eye').forEach(btn => {
      const input = document.getElementById(btn.dataset.pw);
      if (!input) return;
      btn.addEventListener('click', () => {
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        btn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
        btn.setAttribute('aria-pressed', show ? 'true' : 'false');
      });
    });

    const form = document.getElementById('login-form');
    const errorEl = document.getElementById('login-error');

    form.addEventListener('submit', async e => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]');
      const orig = btn.textContent;
      errorEl.hidden = true;
      btn.disabled = true;
      btn.textContent = 'Signing in…';
      try {
        const data = await postJson('login', {
          email: form.email.value.trim(),
          password: form.password.value
        });
        localStorage.setItem('bdmso_user', JSON.stringify({
          accountId: data.accountId,
          fullName: data.fullName,
          email: data.email
        }));
        window.location.href = loginRedirectTo || '/dashboard';
      } catch (err) {
        errorEl.textContent = err.message;
        errorEl.hidden = false;
        btn.disabled = false;
        btn.textContent = orig;
      }
    });

    const signinView  = document.getElementById('signin-view');
    const recoverView = document.getElementById('recover-view');
    document.getElementById('open-recover').addEventListener('click', () => {
      signinView.hidden  = true;
      recoverView.hidden = false;
    });
    document.getElementById('recover-back').addEventListener('click', () => {
      recoverView.hidden = true;
      signinView.hidden  = false;
    });

    const tabs  = document.querySelectorAll('.recover-tab');
    const panes = {
      password: document.getElementById('recover-password'),
      email:    document.getElementById('recover-email'),
    };
    tabs.forEach(t => t.addEventListener('click', () => {
      tabs.forEach(other => {
        const active = other === t;
        other.classList.toggle('is-active', active);
        other.setAttribute('aria-selected', String(active));
      });
      Object.entries(panes).forEach(([k, el]) => { el.hidden = (k !== t.dataset.tab); });
    }));

    const fpForm   = document.getElementById('forgot-password-form');
    const fpError  = document.getElementById('fp-error');
    const fpResult = document.getElementById('fp-result');
    fpForm.addEventListener('submit', async e => {
      e.preventDefault();
      const btn = fpForm.querySelector('button[type=submit]');
      const orig = btn.textContent;
      fpError.hidden = true;
      fpResult.hidden = true;
      btn.disabled = true;
      btn.textContent = 'Sending…';
      try {
        await postJson('forgot-password', { email: fpForm.email.value.trim() });
        fpResult.hidden = false;
      } catch (err) {
        fpError.textContent = err.message;
        fpError.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = orig;
      }
    });

    const feForm     = document.getElementById('forgot-email-form');
    const feError    = document.getElementById('fe-error');
    const feResultOk = document.getElementById('fe-result-ok');
    const feResultNo = document.getElementById('fe-result-none');
    const feEmailEl  = document.getElementById('fe-result-email');
    const fePhone    = document.getElementById('fe-phone');
    const feMemId    = document.getElementById('fe-memberid');
    fePhone.addEventListener('input', () => { if (fePhone.value) feMemId.value = ''; });

    function formatMemberSuffix(raw) {
      const digits = (raw || '').replace(/\D+/g, '').slice(0, 7);
      return digits.length <= 4 ? digits : `${digits.slice(0, 4)}-${digits.slice(4)}`;
    }
    feMemId.addEventListener('input', () => {
      feMemId.value = formatMemberSuffix(feMemId.value);
      if (feMemId.value) fePhone.value = '';
    });
    feForm.addEventListener('submit', async e => {
      e.preventDefault();
      const btn = feForm.querySelector('button[type=submit]');
      const orig = btn.textContent;
      feError.hidden    = true;
      feResultOk.hidden = true;
      feResultNo.hidden = true;
      const phone      = fePhone.value.trim();
      const memberPart = feMemId.value.trim();
      const memberId   = memberPart ? `BdMSO${memberPart}` : '';
      if (!phone && !memberId) {
        feError.textContent = 'Enter your phone number or BdMSO ID.';
        feError.hidden = false;
        return;
      }
      btn.disabled = true;
      btn.textContent = 'Looking up…';
      try {
        const data = await postJson('forgot-email', phone ? { phone } : { memberId });
        if (data.found) {
          feEmailEl.textContent = data.maskedEmail || '';
          feResultOk.hidden = false;
        } else {
          feResultNo.hidden = false;
        }
      } catch (err) {
        feError.textContent = err.message;
        feError.hidden = false;
      } finally {
        btn.disabled = false;
        btn.textContent = orig;
      }
    });
  </script>
</BaseLayout>
