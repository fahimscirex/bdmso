---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { deriveRegState } from "../lib/regState.js";

const title = "STEM and Olympiad Programs for Primary Students - BdMSO";
const description =
  "Year-round STEM, Olympiad prep, lab days, and residential camp programs from BdMSO for primary-school students in Bangladesh.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Programs and Courses",
    description,
    url: "https://bdmso.org/programs",
    about: {
      "@type": "EducationalOrganization",
      name: "Bangladesh Mathematics and Science Olympiad",
      url: "https://bdmso.org",
      description:
        "A platform dedicated to identifying and nurturing early age STEM talent across Bangladesh.",
    },
  },
];

// Server-rendered program cards from the programs collection - replaces the
// legacy client fetch of /data/programs-detail.json. Hidden programs are
// skipped; ordering follows home_order. This mirrors buildProgramsIndex() in
// scripts/build.mjs: cards are emitted into the data-list="all" grid and the
// inline script at the bottom stamps status pills / dots / overlays + wires up
// filters and the detail modal at runtime.
const programs = (await getCollection("programs"))
  .filter((p) => !p.data.hidden)
  .sort((a, b) =>
    (a.data.home_order || "").localeCompare(b.data.home_order || "")
  );

const ICON = {
  person:
    "<svg viewBox='0 0 20 20' fill='currentColor'><path d='M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z'/></svg>",
  clock:
    "<svg viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='1.8'><circle cx='10' cy='10' r='7'/><path d='M10 6v4l2.5 2.5' stroke-linecap='round'/></svg>",
  star: "<svg viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='1.8'><path d='M10 3l2.5 5 5.5.5-4 4 1 5.5L10 15l-5 3 1-5.5-4-4L7.5 8z' stroke-linejoin='round'/></svg>",
};
const CTA_ARROW =
  "<svg viewBox='0 0 20 20' fill='currentColor'><path fill-rule='evenodd' d='M7.3 5.3a1 1 0 011.4 0l4 4a1 1 0 010 1.4l-4 4a1 1 0 11-1.4-1.4L10.6 10 7.3 6.7a1 1 0 010-1.4z'/></svg>";
const BADGE = {
  beginner: ["b-beginner", "Beginner"],
  advanced: ["b-advanced", "Advanced"],
  residential: ["b-residential", "Residential"],
};

const escAttr = (s) =>
  String(s == null ? "" : s)
    .replace(/&/g, "&amp;")
    .replace(/"/g, "&quot;")
    .replace(/</g, "&lt;");
const escHtml = (s) =>
  String(s == null ? "" : s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");

const todayISO = new Date().toISOString().slice(0, 10);

const cards = programs
  .map((entry) => {
    const p = entry.data;
    // Badge: "Open" only when the program has an explicit registration
    // window and today falls inside it. Year-round programs (no dates)
    // and closed ones show their category badge (Beginner/Advanced/...).
    let badgeClass, badgeLabel;
    const regOpen =
      deriveRegState(p.yearRound === true, p.registrationStarts, p.registrationEnds, todayISO) ===
      "open";
    if (regOpen) {
      badgeClass = "b-open";
      badgeLabel = "Open";
    } else {
      [badgeClass, badgeLabel] = BADGE[p.category] || ["b-open", "Open"];
    }
    const dated = !!(p.registrationStarts || p.registrationEnds);
    const facts = [
      [ICON.person, p.audience],
      [ICON.clock, p.duration],
      [ICON.star, p.outcome],
    ]
      .filter(([, v]) => v)
      .map(
        ([icon, v]) =>
          `<div class="p-card-fact">${icon}<span>${escHtml(v)}</span></div>`
      )
      .join("");
    const attrs = [
      `data-slug="${escAttr(entry.id)}"`,
      `data-tags="${escAttr(p.category || "")}"`,
      `data-schedule="${dated ? "dated" : "year-round"}"`,
      p.registrationStarts ? `data-starts="${escAttr(p.registrationStarts)}"` : "",
      p.registrationEnds ? `data-ends="${escAttr(p.registrationEnds)}"` : "",
      p.yearRound ? 'data-year-round="true"' : "",
    ]
      .filter(Boolean)
      .join(" ");
    const fee =
      p.price ||
      (p.feeAmount != null
        ? `৳ ${Number(p.feeAmount).toLocaleString("en-BD")}`
        : "On enquiry");
    return `<a class="p-card" href="/programs/${escAttr(entry.id)}" ${attrs}>
      <div class="p-card-topbar">
        <div class="p-card-topbar-l">
          <span class="p-card-badge ${badgeClass}">${badgeLabel}</span>
        </div>
      </div>
      <h3 class="p-card-title">${escHtml(p.title)}</h3>
      <p class="p-card-desc">${escHtml(p.tagline || "")}</p>
      <div class="p-card-facts">${facts}</div>
      <div class="p-card-foot">
        <span class="p-card-fee">${fee}</span>
        <span class="p-card-cta">Details${CTA_ARROW}</span>
      </div>
    </a>`;
  })
  .join("\n");
---

<BaseLayout
  title={title}
  description={description}
  page="programs"
  canonical="https://bdmso.org/programs"
  image="https://bdmso.org/images/stem.webp"
  jsonLd={jsonLd}
>
  <style is:global slot="head">
    .page-head { background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%); color: white; padding: 80px 0 100px; position: relative; overflow: hidden; }
    .page-head::before { content:""; position:absolute; inset:0; background: radial-gradient(600px 300px at 50% 100%, var(--glow-gold-sm), transparent 60%); }
    .page-head .container { position: relative; z-index: 1; }
    .page-head .eyebrow { background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); margin-bottom: 18px; }
    .page-head h1 { color: white; margin: 0 0 12px; max-width: 880px; }
    .page-head p { color: var(--on-dark-2); margin: 0; font-size: 1.05rem; max-width: 720px; }

    @media (max-width: 800px) {
      .page-head { padding: 56px 0 80px; }
    }

    .prog-wrap { margin-top: -56px; position: relative; z-index: 2; padding-bottom: 96px; }
    .filter-bar { display: flex; gap: 6px; padding: 8px; background: white; border: 1px solid var(--line); border-radius: 14px; box-shadow: var(--shadow-sm); margin-bottom: 22px; overflow-x: auto; max-width: 100%; align-items: center; }
    .filter-bar button { padding: 8px 14px; font-weight: 600; font-size: 13px; color: var(--ink-2); border-radius: 10px; white-space: nowrap; flex-shrink: 0; border: none; background: none; cursor: pointer; }
    .filter-bar button.active { background: var(--navy-900); color: white; }
    .filter-bar button:hover:not(.active) { background: var(--navy-50); color: var(--navy-800); }
    .filter-divider { width: 1px; height: 22px; background: var(--line); flex-shrink: 0; margin: 0 4px; }

    .p-section { margin-bottom: 36px; }
    .p-section:last-child { margin-bottom: 0; }
    .p-section-head {
      display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
      margin: 0 0 16px;
    }
    .p-section-head h2 {
      font-size: 1.05rem; font-weight: 700; color: var(--navy-900);
      text-transform: uppercase; letter-spacing: 0.08em; margin: 0;
    }
    .p-section-head .count {
      font-size: 12px; font-weight: 600; color: var(--ink-3);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .p-section-empty {
      background: white; border: 1px dashed var(--line); border-radius: var(--r);
      padding: 24px; text-align: center; color: var(--ink-3); font-size: 14px;
    }
    .p-section-tag {
      display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px;
      border-radius: 999px; letter-spacing: 0.08em; text-transform: uppercase;
      vertical-align: middle; margin-right: 10px;
    }
    .p-section-tag.ongoing  { background: #dcfce7; color: #166534; }
    .p-section-tag.upcoming { background: #fef3c7; color: #92400e; }
    .p-section-tag.rolling  { background: #e0e7ff; color: #3730a3; }

    /* Card grid sits on a slightly cooler bg "tray" so white cards pop. */
    .prog-wrap { background: #f4f6fb; border-radius: 20px; padding: 26px; }
    .p-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 22px; align-items: stretch; }

    /* All-light cards: elevated, generous shadow, accent stripe on the
       left edge that reveals on hover. Each card is a real <a> to
       /programs/<slug> so crawlers, middle-click and right-click work;
       JS intercepts the left-click and opens the modal. */
    .p-card {
      background: white;
      border: 1px solid #e6e9f1;
      border-radius: 14px;
      padding: 20px 20px 18px;
      display: flex; flex-direction: column; gap: 13px;
      text-decoration: none; color: inherit;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      position: relative; overflow: hidden;
      box-shadow:
        0 1px 2px rgba(15, 23, 42, 0.04),
        0 6px 16px rgba(15, 23, 42, 0.05);
    }
    .p-card:hover  {
      border-color: #c8cfdf;
      transform: translateY(-4px);
      box-shadow:
        0 1px 2px rgba(15, 23, 42, 0.05),
        0 14px 28px rgba(30, 58, 138, 0.14),
        0 24px 48px rgba(30, 58, 138, 0.08);
    }
    .p-card:focus-visible { outline: 2px solid var(--navy-700); outline-offset: 2px; }

    .p-card-topbar { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .p-card-topbar-l { display:flex; align-items:center; gap:10px; min-width:0; }
    .p-card-no { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); font-weight: 600; }
    .p-card-badge {
      font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 999px;
      letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap;
      background: var(--navy-50); color: var(--navy-800);
    }
    .p-card-badge.b-beginner   { background: #ede9fe; color: #5b21b6; }
    .p-card-badge.b-advanced   { background: #dbeafe; color: #1e40af; }
    .p-card-badge.b-open       { background: #dcfce7; color: #166534; }
    .p-card-badge.b-residential{ background: #fef3c7; color: #92400e; }

    .p-card-dot {
      position: relative; display: inline-flex; width: 9px; height: 9px; flex-shrink: 0;
    }
    .p-card-dot::before, .p-card-dot::after {
      content:""; position: absolute; inset: 0; border-radius: 50%; background: #16a34a;
    }
    .p-card-dot::before { animation: pcardping 1.6s cubic-bezier(0,0,.2,1) infinite; opacity: 0.6; }
    @keyframes pcardping { 75%, 100% { transform: scale(2); opacity: 0; } }

    /* Upcoming / will-be-announced cards: card content fades, an overlay
       message is centered. The card still links to the detail page so
       parents can preview. */
    .p-card--soon > :not(.p-card-overlay),
    .p-card--rolling > :not(.p-card-overlay) { opacity: 0.4; }
    .p-card-overlay {
      position: absolute; inset: 0; z-index: 3;
      display: flex; align-items: center; justify-content: center;
      text-align: center; padding: 0 14px;
      font-family: var(--font-display); font-size: 0.95rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--navy-900);
      pointer-events: none;
    }
    .p-card--soon:hover, .p-card--rolling:hover { transform: none; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 6px 16px rgba(15, 23, 42, 0.05); }

    .p-card-title { font-size: 1rem; font-weight: 700; color: var(--navy-900); margin: 0; line-height: 1.3; letter-spacing: -0.005em; }
    .p-card-desc  { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.55; flex-grow: 1; }

    .p-filter-info { font-size: 12.5px; color: var(--ink-3); margin: 16px 0 0; font-weight: 600; letter-spacing: 0.04em; }

    .p-card-facts { display: grid; gap: 7px; padding-top: 12px; border-top: 1px solid var(--line); }
    .p-card-fact  { display: flex; align-items: flex-start; gap: 9px; font-size: 12.5px; color: var(--ink-1); line-height: 1.45; }
    .p-card-fact svg { width: 14px; height: 14px; color: var(--ink-3); flex-shrink: 0; margin-top: 1px; }
    .p-card-fact span { min-width: 0; overflow-wrap: anywhere; }

    .p-card-foot {
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
      padding-top: 4px; margin-top: 2px;
    }
    .p-card-fee  { font-size: 13.5px; font-weight: 700; color: var(--navy-900); }
    .p-card-cta  {
      display:inline-flex; align-items:center; gap:4px; font-size:13px; font-weight:700;
      color: var(--navy-700);
    }
    .p-card-cta svg { width: 14px; height: 14px; transition: transform 0.2s; }
    .p-card:hover .p-card-cta svg { transform: translateX(3px); }

    /* ─── Modal ──────────────────────────────────────────────────── */
    .p-modal { position: fixed; inset: 0; z-index: 200; display: flex; justify-content: center; align-items: center;
      background: rgba(15, 23, 42, 0.55); -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
      padding: 24px 16px; }
    .p-modal[hidden] { display: none; }
    /* The shell itself is the scroll container, capped at 90vh so the
       sticky header has a fixed top to stick to instead of fighting the
       viewport scroll. */
    /* Modal shell. Transition + @starting-style instead of keyframe so a
       user reopening the modal quickly doesn't see a restart-from-zero.
       transform-origin stays default (center) - modals are not anchored to
       a trigger. */
    .p-modal-shell {
      background: white; width: 100%; max-width: 880px; max-height: 90vh;
      border-radius: var(--r-xl); box-shadow: 0 30px 60px -15px rgba(0,0,0,0.4);
      display: flex; flex-direction: column; overflow: hidden;
      transition:
        opacity var(--dur-modal) var(--ease-out),
        transform var(--dur-modal) var(--ease-out);
    }
    @starting-style {
      .p-modal-shell { opacity: 0; transform: translateY(8px) scale(0.98); }
    }

    .p-modal-head {
      flex: 0 0 auto;
      display: flex; align-items: center; gap: 12px;
      padding: 12px 18px; border-bottom: 1px solid var(--line);
      background: white;
    }
    .p-modal-crumb { font-size: 13px; color: var(--ink-3); display: flex; align-items: center; gap: 6px; min-width: 0; flex: 1; }
    .p-modal-crumb a { color: var(--ink-3); text-decoration: none; }
    .p-modal-crumb a:hover { color: var(--navy-700); }
    .p-modal-crumb .sep { color: var(--ink-4, #cbd5e1); }
    .p-modal-crumb .now { color: var(--navy-900); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .p-modal-fullpage {
      font-size: 12.5px; font-weight: 600; color: var(--navy-700);
      padding: 6px 11px; border: 1px solid var(--line); border-radius: 8px;
      text-decoration: none; white-space: nowrap;
    }
    .p-modal-fullpage:hover { background: var(--navy-50); }
    .p-modal-close {
      width: 30px; height: 30px; border-radius: 50%; background: var(--bg-alt);
      display: flex; align-items: center; justify-content: center;
      border: none; cursor: pointer; color: var(--ink-2); font-size: 18px; line-height: 1;
      transition:
        background-color var(--dur-ui) ease,
        color var(--dur-ui) ease,
        transform var(--dur-press) var(--ease-out);
    }
    @media (hover: hover) and (pointer: fine) {
      .p-modal-close:hover { background: var(--line); color: var(--navy-900); }
    }
    .p-modal-close:active { transform: scale(0.9); }
    .p-modal-fullpage {
      transition:
        background-color var(--dur-ui) ease,
        transform var(--dur-press) var(--ease-out);
    }
    .p-modal-fullpage:active { transform: scale(0.97); }

    /* The body is the scrollable region inside the shell. Header stays
       pinned at top because it's flex:0 outside this scroll context. */
    .p-modal-body { flex: 1 1 auto; overflow-y: auto; padding: 0; min-height: 180px; }
    .p-modal-loading {
      padding: 60px 20px; text-align: center; color: var(--ink-3); font-size: 14px;
    }

    /* Modal-only compact hero: dark gradient band with eyebrow, title,
       tagline, and inline fact pills. */
    .p-modal-hero {
      background: linear-gradient(180deg, #1b2545 0%, #141d39 100%);
      color: white; padding: 20px 22px 18px;
      position: relative; overflow: hidden;
    }
    .p-modal-hero::before {
      content:""; position:absolute; inset:0;
      background: radial-gradient(400px 180px at 50% 100%, rgba(247,180,46,0.08), transparent 70%);
      pointer-events: none;
    }
    .p-modal-hero > * { position: relative; z-index: 1; }
    .p-modal-hero .title-row {
      display: flex; align-items: flex-start; justify-content: space-between; gap: 14px;
      margin-bottom: 8px;
    }
    .p-modal-hero .eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      background: rgba(247,180,46,0.14); color: #fcd34d;
      padding: 3px 10px; border-radius: 999px; margin: 4px 0 0; flex-shrink: 0;
      white-space: nowrap;
    }
    .p-modal-hero h1 {
      font-size: 1.25rem; line-height: 1.25;
      margin: 0; color: white; letter-spacing: -0.005em;
      flex: 1; min-width: 0;
    }
    .p-modal-hero .lede {
      font-size: 13px; line-height: 1.5; color: rgba(255,255,255,0.7);
      margin: 0 0 16px; max-width: 640px;
    }
    /* One row of fact tiles across the hero - all equal width, text wraps
       within each tile. Falls back to a wrapping grid only on narrow screens. */
    .p-modal-hero .facts {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(0, 1fr);
      gap: 8px;
    }
    .p-modal-hero .fact {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; padding: 10px 12px; min-width: 0;
      display: flex; flex-direction: column; justify-content: center;
    }
    .p-modal-hero .fact .k {
      font-size: 9.5px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em;
      font-weight: 700; margin-bottom: 2px;
    }
    .p-modal-hero .fact .v { font-size: 12px; font-weight: 600; color: white; line-height: 1.3; }
    @media (max-width: 640px) {
      .p-modal-hero .facts {
        grid-auto-flow: row;
        grid-template-columns: repeat(2, 1fr);
        grid-auto-columns: auto;
      }
    }

    .p-modal-content { padding: 0; }
    .p-modal-inner { padding: 20px 22px 24px; }
    .p-modal-inner .pd-grid { grid-template-columns: minmax(0, 1.4fr) minmax(240px, 300px); gap: 18px; }
    .p-modal-inner .pd-main {
      box-shadow: none; border: 1px solid var(--line); padding: 18px;
      font-size: 13.5px;
    }
    .p-modal-inner .pd-main img.cover { display: none; }
    .p-modal-inner .pd-main h2 { font-size: 1.05rem; margin: 18px 0 8px; }
    .p-modal-inner .pd-main h2:first-of-type { margin-top: 0; }
    .p-modal-inner .pd-main p { line-height: 1.6; margin: 0 0 0.9em; }
    .p-modal-inner .pd-main ul li { font-size: 13px; line-height: 1.55; }
    .p-modal-inner .pd-side { position: static; top: auto; gap: 12px; }
    .p-modal-inner .pd-card { box-shadow: none; border: 1px solid var(--line); padding: 18px; }
    .p-modal-inner .pd-price { font-size: 1.3rem; margin-bottom: 4px; }
    .p-modal-inner .pd-schedule { font-size: 12.5px; margin-bottom: 14px; }
    /* Modal's Register CTA: tighter than the full-page version. */
    .p-modal-inner .pd-cta {
      padding: 10px 14px; font-size: 14px; font-weight: 700;
    }

    @media (max-width: 760px) {
      /* Stay a dismissible card on mobile - a small inset keeps the
         backdrop visible around it and the head (× + full-page link)
         clear of the viewport edge, so it never reads as a trapping
         full page. */
      .p-modal { padding: 12px; }
      .p-modal-shell { max-height: 90vh; max-width: 100%; }
      .p-modal-inner { padding: 16px; }
      .p-modal-inner .pd-grid,
      .p-modal-content .pd-grid { grid-template-columns: 1fr; gap: 16px; }
      .p-modal-content .pd-grid { padding: 16px; }
    }

    /* Lock body scroll while modal is open. */
    body.modal-open { overflow: hidden; }
  </style>

  <main>
    <section class="page-head"><div class="container">
      <span class="eyebrow">Programs &amp; Courses</span>
      <!-- This is the only real H1 on /programs. Two other <h1> occurrences
           further down sit inside JS template literals for the modal hero
           (`p-modal-hero h1`) and only mount into the DOM when a modal opens,
           at which point this page-head section is visually covered. SEO
           audits that count <h1> in raw HTML will see 3; the rendered DOM
           has exactly 1 at any given time. -->
      <h1>Your journey to STEM excellence starts here.</h1>
      <p>Build a strong foundation through these official camps and training modules, from beginner-friendly workshops to international-level residential camps.</p>
    </div></section>

    <section class="container prog-wrap">
      <div class="filter-bar">
        <button class="active" data-filter="all">All programs</button>
        <span class="filter-divider" aria-hidden="true"></span>
        <button data-filter="open" title="Registration is currently open">Registration open</button>
        <button data-filter="soon" title="Registration window hasn't opened yet">Upcoming intake</button>
        <span class="filter-divider" aria-hidden="true"></span>
        <button data-filter="beginner">Beginner</button>
        <button data-filter="advanced">Advanced</button>
        <button data-filter="residential">Residential</button>
      </div>

      <!-- One source-of-truth list. JS at the bottom of this file classifies
           each card into Ongoing / Upcoming / Year-round based on data-starts
           / data-ends (today's date vs the window). Year-round cards have no
           dates. data-href is where a whole-card click lands. -->

      <!-- Single unified grid. Each card carries its own status pill
           (Open now / Opens soon / Year-round) so the registration-state
           info lives on the card. The count text is hidden by default
           and only shown when the user filters down. Cards are
           server-rendered from the programs collection. -->
      <div class="p-list" data-list="all" set:html={cards}></div>
      <div class="p-filter-info" id="all-count" hidden></div>
      <div class="p-section-empty" id="all-empty" data-empty hidden>No programs match this filter.</div>
    </section>
  </main>

  <!-- Program detail modal. Content is fetched on demand from /programs/<slug>
       so the static SEO-indexed page and the modal share the same source. -->
  <div id="program-modal" class="p-modal" hidden role="dialog" aria-modal="true" aria-labelledby="p-modal-title-text">
    <div class="p-modal-shell" role="document">
      <header class="p-modal-head">
        <div class="p-modal-crumb">
          <a href="/programs">Programs</a>
          <span class="sep">›</span>
          <span class="now" id="p-modal-title-text">Loading…</span>
        </div>
        <a class="p-modal-fullpage" id="p-modal-fullpage" href="/programs" target="_blank" rel="noopener">Open full page ↗</a>
        <button class="p-modal-close" type="button" aria-label="Close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
      </header>
      <div class="p-modal-body">
        <div class="p-modal-loading" id="p-modal-loading">Loading…</div>
        <div class="p-modal-content" id="p-modal-content" hidden></div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function () {
    // ── 1. Stamp each card with a status pill (Open / Soon / Rolling)
    //    and move all cards into the single unified grid. Order: open
    //    registrations first, then opens-soon, then year-round. Cards are
    //    server-rendered into [data-list="all"]; this only enhances them.
    const grid    = document.querySelector('[data-list="all"]');
    const cardEls = [...grid.querySelectorAll('.p-card')];

    const todayISO = (() => {
      const d = new Date();
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    })();

    const STATUS_LABEL = { open: 'Open now', soon: 'Opens soon', closed: 'Registration closed' };
    const ORDER        = { open: 0, soon: 1, closed: 2 };

    // Canonical rule (copy of deriveRegState): state is derived from the date
    // window plus the year-round flag (always open). 'upcoming' maps to the
    // 'soon' visual bucket below.
    function deriveRegState(yearRound, starts, ends, today) {
      if (yearRound) return 'open';
      if (starts && today < starts) return 'upcoming';
      if (ends && today > ends) return 'closed';
      if (starts || ends) return 'open';
      return 'closed';
    }
    function statusFor(card) {
      const state = deriveRegState(
        card.dataset.yearRound === 'true',
        card.dataset.starts,
        card.dataset.ends,
        todayISO
      );
      return state === 'upcoming' ? 'soon' : state;
    }

    const all = cardEls.map((card) => ({
      card, status: statusFor(card)
    })).filter(({ status }) => status !== null);

    // Sort: open → soon → rolling. Stable within group preserves source order.
    all.sort((a, b) => ORDER[a.status] - ORDER[b.status]);

    // Stamp data-status + apply visual treatment per status:
    //   open    - green pulsing dot in the topbar's right slot
    //   soon    - card faded, "Upcoming" overlay centered
    //   rolling - card faded, "Will be announced" overlay centered
    for (const { card, status } of all) {
      card.dataset.status = status;
      if (status === 'open') {
        const topbar = card.querySelector('.p-card-topbar');
        if (topbar && !topbar.querySelector('.p-card-dot')) {
          const dot = document.createElement('span');
          dot.className = 'p-card-dot';
          dot.setAttribute('aria-hidden', 'true');
          topbar.appendChild(dot);
        }
      } else if (status === 'soon') {
        card.classList.add('p-card--soon');
        const ov = document.createElement('div');
        ov.className = 'p-card-overlay';
        ov.textContent = 'Upcoming';
        card.appendChild(ov);
      } else if (status === 'closed') {
        card.classList.add('p-card--soon');
        const ov = document.createElement('div');
        ov.className = 'p-card-overlay';
        ov.textContent = 'Registration closed';
        card.appendChild(ov);
      }
    }

    // Append everything to the single grid. The count line stays hidden
    // until the user actually filters - no point telling people there
    // are "12 programs" when 12 cards are right there in front of them.
    const count = document.getElementById('all-count');
    for (const { card } of all) grid.appendChild(card);
    const total = all.length;

    // ── 2. Modal: open on card click, fetch /programs/<slug> on demand,
    //    inject only the body content so the modal stays small. The static
    //    page remains canonical for SEO and direct shares.
    const modal      = document.getElementById('program-modal');
    const modalTitle = document.getElementById('p-modal-title-text');
    const modalFull  = document.getElementById('p-modal-fullpage');
    const modalLoad  = document.getElementById('p-modal-loading');
    const modalBody  = document.getElementById('p-modal-content');
    const cache      = Object.create(null);

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s == null ? '' : String(s);
      return d.innerHTML;
    }

    async function loadIntoModal(slug, href, title) {
      modalTitle.textContent = title || 'Program details';
      modalFull.href         = href;
      modalBody.innerHTML    = '';
      modalBody.hidden       = true;
      modalLoad.hidden       = false;
      modalLoad.textContent  = 'Loading…';

      let html = cache[slug];
      if (!html) {
        try {
          const res = await fetch(href, { credentials: 'same-origin' });
          if (!res.ok) throw new Error('Fetch failed: ' + res.status);
          const text = await res.text();
          const doc  = new DOMParser().parseFromString(text, 'text/html');

          // ── Build the modal hero from the fetched static page.
          const pdWrap   = doc.querySelector('.pd-wrap');
          const progBody = doc.querySelector('.prog-body');

          if (pdWrap) {
            const h1Text      = doc.querySelector('.pd-hero h1')?.textContent.trim() || title || '';
            const ledeText    = doc.querySelector('.pd-hero p.lede')?.textContent.trim() || '';
            const eyebrowText = doc.querySelector('.pd-hero .eyebrow')?.textContent.trim() || '';

            // Promote the side card's facts (Audience / Duration / Format /
            // Outcome) into the hero as inline tiles so the hero "owns" the
            // at-a-glance facts the way the mockup does. The "Level" fact
            // is dropped because it duplicates the audience info already
            // shown in "Who it's for".
            const factsHtml = [...pdWrap.querySelectorAll('.pd-side .pd-fact')]
              .filter((f) => {
                const k = f.querySelector('.k')?.textContent.trim().toLowerCase() || '';
                return k !== 'level';
              })
              .map((f) => {
                const k = f.querySelector('.k')?.textContent.trim() || '';
                const v = f.querySelector('.v')?.textContent.trim() || '';
                return `<div class="fact"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`;
              }).join('');

            const heroHtml = `<section class="p-modal-hero">
              <div class="title-row">
                <h1>${esc(h1Text)}</h1>
                ${eyebrowText ? `<span class="eyebrow">${esc(eyebrowText)}</span>` : ''}
              </div>
              ${ledeText ? `<p class="lede">${esc(ledeText)}</p>` : ''}
              ${factsHtml ? `<div class="facts">${factsHtml}</div>` : ''}
            </section>`;

            // Clone the body so we can strip the now-duplicated facts grid
            // out of the side card before injection.
            const bodyClone = pdWrap.cloneNode(true);
            bodyClone.querySelector('.pd-side .pd-facts')?.remove();
            // The cover image in the main panel was an extra visual that
            // doesn't read well at modal scale; the hero already sells the
            // program, so we drop it.
            bodyClone.querySelector('.pd-main img.cover')?.remove();

            html = heroHtml + `<div class="p-modal-inner">${bodyClone.innerHTML}</div>`;
          } else {
            html = `<div class="p-modal-inner"><p style="padding:40px;text-align:center;color:var(--ink-3);">Content unavailable. <a href="${esc(href)}">Open the full page →</a></p></div>`;
          }
          cache[slug] = html;
        } catch (err) {
          modalLoad.textContent = 'Could not load details. ';
          const a = document.createElement('a');
          a.href = href;
          a.textContent = 'Open the full page →';
          modalLoad.appendChild(a);
          return;
        }
      }
      modalLoad.hidden    = true;
      modalBody.innerHTML = html;
      modalBody.hidden    = false;
      // Scroll the modal body to top in case it was reopened mid-scroll.
      modalBody.parentElement.scrollTop = 0;
    }

    function openModalFor(card) {
      const slug  = card.dataset.slug;
      const href  = card.getAttribute('href');
      const title = card.querySelector('.p-card-title')?.textContent.trim();
      document.body.classList.add('modal-open');
      modal.hidden = false;
      if (location.hash.replace('#', '') !== slug) {
        // Update URL without scroll-jumping or adding a stack entry per open.
        history.replaceState(null, '', '#' + slug);
      }
      loadIntoModal(slug, href, title);
    }

    function closeModal() {
      modal.hidden = true;
      document.body.classList.remove('modal-open');
      if (location.hash) history.replaceState(null, '', location.pathname + location.search);
    }

    // Click handler on each card. Anchors still navigate on middle-click,
    // cmd/ctrl-click, right-click "open in new tab" - we only intercept
    // a plain left-click.
    document.querySelectorAll('.p-card').forEach((card) => {
      if (card.dataset.noModal) return;
      card.addEventListener('click', (e) => {
        if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        e.preventDefault();
        openModalFor(card);
      });
    });

    // Close: button, backdrop click, ESC.
    modal.querySelector('.p-modal-close').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // Deep-link: /programs#stem-foundation opens that card's modal on load.
    function openFromHash() {
      const slug = location.hash.replace('#', '');
      if (!slug) return;
      const card = document.querySelector(`.p-card[data-slug="${CSS.escape(slug)}"]`);
      if (card && !card.dataset.noModal) openModalFor(card);
    }
    window.addEventListener('hashchange', openFromHash);
    openFromHash();

    // ── 3. Filter bar: filter cards by tag (beginner/advanced/open/residential)
    //    OR by registration status (open/soon/rolling). Empty-state shown
    //    when nothing matches.
    const filterBtns = document.querySelectorAll('.filter-bar button');
    const emptyEl    = document.getElementById('all-empty');
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        let visible = 0;
        document.querySelectorAll('[data-list="all"] .p-card').forEach((item) => {
          const tags   = item.dataset.tags.split(' ');
          const status = item.dataset.status;
          const match  = filter === 'all'
            || tags.includes(filter)
            || status === filter;
          item.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (filter === 'all') {
          count.hidden = true;
        } else {
          count.hidden = false;
          count.textContent = `Showing ${visible} of ${total} programs`;
        }
        emptyEl.hidden = visible > 0;
      });
    });
  })();
  </script>
</BaseLayout>
