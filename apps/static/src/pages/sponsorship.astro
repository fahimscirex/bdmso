---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Sponsor BdMSO 2026 - Partnership Opportunities";
const description =
  "Partner with BdMSO 2026 - Title Sponsor, Powered By, and custom partnership opportunities reaching 10,000+ primary students nationwide.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Collaborate with BdMSO",
    description:
      "Partner with BdMSO 2026 - Title Sponsor, Powered By, and custom partnership opportunities reaching 10,000+ primary students nationwide.",
    url: "https://bdmso.org/sponsorship",
    about: {
      "@type": "EducationalOrganization",
      name: "Bangladesh Mathematics and Science Olympiad",
      url: "https://bdmso.org",
      description:
        "A platform dedicated to identifying and nurturing early age STEM talent across Bangladesh.",
    },
  },
];
---

<BaseLayout
  title={title}
  description={description}
  page="sponsorship"
  canonical="https://bdmso.org/sponsorship"
  image="https://bdmso.org/images/national-round-winners.webp"
  jsonLd={jsonLd}
>
  <style is:global slot="head">
    .page-head { background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%); color: white; padding: 80px 0 100px; position: relative; overflow: hidden; }
    .page-head::before { content:""; position:absolute; inset:0; background: radial-gradient(600px 300px at 50% 100%, var(--glow-gold-sm), transparent 60%); }
    .page-head .eyebrow { background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); margin-bottom: 18px; }
    .page-head h1 { color: white; max-width: 760px; margin: 0 0 12px; }
    .page-head p { color: var(--on-dark-2); max-width: 620px; margin: 0; font-size: 1.05rem; }

    .wrap { margin-top: -56px; position: relative; z-index: 2; padding-bottom: 96px; display: flex; flex-direction: column; gap: 32px; }
    .panel { background: white; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 32px; }

    .reach { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .reach .stat { padding: 20px; background: var(--bg-alt); border-radius: var(--r); text-align: center; }
    .reach .n { font-family: var(--font-display); font-size: 2rem; color: var(--navy-900); font-weight: 700; line-height: 1; margin-bottom: 6px; }
    .reach .t { font-size: 12.5px; color: var(--ink-3); }
    @media (max-width: 700px) { .reach { grid-template-columns: 1fr 1fr; } }
    /* Below ~480px two columns can't hold the large stat numbers (e.g. "10,000+"
       at 2rem) without overflowing the viewport, so stack to one column. */
    @media (max-width: 480px) { .reach { grid-template-columns: 1fr; } .panel { padding: 22px; } }

    .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .tier {
      padding: 28px; border-radius: var(--r-lg);
      border: 1px solid var(--line); background: white;
      display: flex; flex-direction: column; gap: 14px;
    }
    .tier.title { background: linear-gradient(180deg, var(--navy-900), var(--navy-darker)); color: white; border-color: var(--navy-900); }
    .tier.title h3 { color: white; } .tier.title p, .tier.title li { color: var(--on-dark); }
    .tier.platinum { border-color: var(--gold-500); background: linear-gradient(180deg, var(--gold-100), white); }
    .tier .kind { font-size: 11px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--navy-700); }
    .tier.title .kind { color: var(--gold-500); }
    .tier.platinum .kind { color: var(--icon-gold); }
    .tier h3 { font-size: 1.4rem; margin: 0; }
    .tier .price { font-family: var(--font-display); font-size: 1.6rem; color: var(--navy-900); font-weight: 700; }
    .tier.title .price { color: var(--gold-500); }
    .tier ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; font-size: 14px; }
    .tier li { display: flex; gap: 10px; align-items: flex-start; }
    .tier li::before { content: "✓"; color: var(--gold-600); font-weight: 700; flex-shrink: 0; }
    .tier.title li::before { color: var(--gold-500); }
    @media (max-width: 900px) { .tiers { grid-template-columns: 1fr; } }

    .cta-form { display: grid; grid-template-columns: 1.2fr 1fr; gap: 32px; align-items: stretch; }
    .cta-form .side { background: var(--navy-900); color: white; border-radius: var(--r-lg); padding: 32px; display: flex; flex-direction: column; gap: 14px; justify-content: center; }
    .cta-form .side h2 { color: white; }
    .cta-form .side p { color: var(--on-dark); }
    .cta-form form { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .cta-form form .full { grid-column: span 2; }
    .cta-form form label { font-size: 13px; font-weight: 600; color: var(--navy-900); margin-bottom: 5px; display: block; }
    .cta-form form input, .cta-form form textarea, .cta-form form select {
      padding: 11px 14px; font-size: 15px; border: 1px solid var(--line); border-radius: 10px; background: white; width: 100%;
      font-family: inherit; color: var(--ink);
    }
    .form-status {
      margin-top: 14px;
      min-height: 24px;
      font-size: 14px;
      font-weight: 600;
    }
    .form-status[data-kind="error"] { color: var(--color-error); }
    .form-status[data-kind="success"] { color: var(--color-success); }
    @media (max-width: 800px) { .cta-form { grid-template-columns: 1fr; } .cta-form form { grid-template-columns: 1fr; } .cta-form form .full { grid-column: auto; } }
  </style>

  <main>
    <section class="page-head"><div class="container">
      <span class="eyebrow">Sponsorship</span>
      <h1>Collaborate with BdMSO</h1>
      <p>Join a movement that's building Bangladesh's next generation of mathematicians and scientists - starting at primary school.</p>
    </div></section>

    <section class="container wrap">

      <div class="panel">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:20px; flex-wrap:wrap; margin-bottom:24px;">
          <div><span class="eyebrow">Our Reach</span><h2 style="margin-top:10px;">Audience at a glance.</h2></div>
          <a class="btn btn-gold" target="_blank" rel="noopener" href="downloads/BdMSO-Partnership-Deck-2026.pdf">⬇ Sponsorship Deck (PDF)</a>
        </div>
        <div class="reach">
          <div class="stat"><div class="n">10,000+</div><div class="t">Students &amp; parents reached annually</div></div>
          <div class="stat"><div class="n">100+</div><div class="t">Partner schools across Bangladesh</div></div>
          <div class="stat"><div class="n">10 yrs+</div><div class="t">Of organizing experience</div></div>
          <div class="stat"><div class="n">500K+</div><div class="t">Combined social reach</div></div>
        </div>
      </div>

      <div class="panel">
        <span class="eyebrow">Partnership Benefits</span>
        <h2 style="margin:10px 0 24px;">Choose the tier that fits your brand.</h2>
        <div class="tiers">
          <div class="tier title">
            <span class="kind">Title Sponsor</span>
            <h3>Exclusive · 1 seat</h3>
            <div class="price">Custom</div>
            <ul>
              <li>Naming rights - "[Your Brand] BdMSO 2026"</li>
              <li>Bangladesh Delegation seat in Jakarta (1 rep)</li>
              <li>Full demographic &amp; insights data sharing</li>
              <li>Top logo on jerseys, certificates, medals &amp; all media</li>
              <li>Speaking slots at all major events</li>
              <li>Content rights - feature medalists in your campaigns</li>
            </ul>
          </div>
          <div class="tier platinum">
            <span class="kind">Powered By</span>
            <h3>Exclusive · 1 seat</h3>
            <div class="price">Custom</div>
            <ul>
              <li>Naming rights - "BdMSO 2026 Powered by [Your Brand]"</li>
              <li>Performance data &amp; participant demographics access</li>
              <li>Second-largest logo on collaterals, backdrops &amp; T-shirts</li>
              <li>Speaking slots at the National Olympiad, camps &amp; press briefings</li>
              <li>Premium stall placement at the National Olympiad</li>
            </ul>
          </div>
          <div class="tier">
            <span class="kind">Custom Partner</span>
            <h3>Open tier</h3>
            <div class="price">Custom</div>
            <ul>
              <li>Custom logo on website</li>
              <li>Acknowledgement at key events</li>
              <li>Social media features</li>
              <li>Annual impact report</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="cta-form">
        <div class="side">
          <span class="eyebrow" style="background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); align-self:flex-start;">Start the conversation</span>
          <h2>Let's build something together.</h2>
          <p>Share a few details about your organization and we'll get back within two working days with a tailored deck and a call invite.</p>
          <p style="font-size:14px; margin-top:10px;"><strong style="color:white;">support@bdmso.org</strong></p>
        </div>
        <div class="panel" style="margin:0;">
          <form id="sponsorship-form">
            <div><label>Organization</label><input id="sp-organization" required placeholder="Company or foundation" /></div>
            <div><label>Contact person</label><input id="sp-contact" required placeholder="Your full name" /></div>
            <div><label>Email</label><input id="sp-email" required type="email" placeholder="name@company.com" /></div>
            <div><label>Phone</label><input id="sp-phone" placeholder="+880 ..." /></div>
            <div class="full"><label>Interested in</label>
              <select id="sp-interest"><option>Title Sponsor</option><option>Powered By</option><option>Custom</option></select>
            </div>
            <div class="full"><label>Tell us more</label><textarea id="sp-message" rows="4" placeholder="Your goals, audience, timelines…" required></textarea></div>
            <div class="full"><button class="btn btn-primary btn-lg" id="sponsorship-submit" style="width:100%;" type="submit">Send Enquiry</button></div>
            <div class="full"><div class="form-status" id="sponsorship-status" aria-live="polite"></div></div>
          </form>
        </div>
      </div>

    </section>
  </main>

  <script type="module" src="/js/sponsorship.js" is:inline></script>
</BaseLayout>
