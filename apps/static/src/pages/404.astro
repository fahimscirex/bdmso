---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page not found - BdMSO";
const description = "";
---

<BaseLayout title={title} description={description} page="404" canonical="https://bdmso.org/404" robots="noindex,follow">
  <style is:global slot="head">
    .notfound-wrap {
      min-height: calc(100vh - 72px);
      display: flex; align-items: center; justify-content: center;
      padding: 64px 24px;
      background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%);
      color: white; position: relative; overflow: hidden;
    }
    .notfound-wrap::before {
      content: ""; position: absolute; inset: 0;
      background: radial-gradient(800px 400px at 50% 50%, var(--glow-gold-sm), transparent 60%);
      pointer-events: none;
    }
    .notfound-card {
      position: relative; z-index: 1;
      text-align: center; max-width: 560px; width: 100%;
    }
    .notfound-card .eyebrow {
      background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk);
      margin-bottom: 18px;
    }
    .notfound-card h1 {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.05;
      color: white; margin: 0 0 16px;
    }
    .notfound-card .code {
      font-family: var(--font-mono); font-size: 14px;
      color: var(--gold-500); letter-spacing: 0.18em; text-transform: uppercase;
      margin-bottom: 20px;
    }
    .notfound-card p { color: var(--on-dark-2); font-size: 1.05rem; margin: 0 0 32px; }
    .notfound-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .notfound-links {
      margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--navy-border-dk);
      display: flex; gap: 18px; justify-content: center; flex-wrap: wrap;
      font-size: 14px;
    }
    .notfound-links a {
      color: var(--on-dark-2); text-decoration: none;
      border-bottom: 1px solid var(--navy-border-dk);
      padding-bottom: 1px;
    }
    .notfound-links a:hover { color: var(--gold-500); border-color: var(--gold-500); }
  </style>

    <section class="notfound-wrap">
      <div class="notfound-card">
        <span class="eyebrow">Page not found</span>
        <div class="code">404</div>
        <h1>This page took a wrong turn.</h1>
        <p>The link you followed might be broken, or the page may have moved. Head back to the home page or try one of the popular destinations below.</p>
        <div class="notfound-actions">
          <a class="btn btn-gold btn-lg" href="/">← Back to home</a>
          <a class="btn btn-ghost btn-lg" href="/programs">Browse programs</a>
        </div>
        <div class="notfound-links">
          <a href="/about">About BdMSO</a>
          <a href="/team">Team</a>
          <a href="/results">Results</a>
          <a href="/resources">Resources</a>
          <a href="/blog">Blog</a>
          <a href="/sponsorship">Collaborate</a>
        </div>
      </div>
    </section>
</BaseLayout>
