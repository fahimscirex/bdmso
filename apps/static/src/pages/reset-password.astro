---
// Standalone auth page (no site header/footer). noindex. Ported from the legacy
// public/reset-password.html during the Astro cutover; the vanilla submit script
// is kept verbatim as an inline script.
import Img from "../components/Img.astro";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reset password - BdMSO</title>
    <meta name="robots" content="noindex,follow" />
    <meta name="theme-color" content="#0b1b3f" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>
    <link rel="stylesheet" href="/css/styles.css" />
    <style is:global>
      .rp-shell { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px; background: var(--bg-alt, #f1f3f7); }
      .rp-card { background: white; border: 1px solid var(--line); border-radius: 16px; padding: 36px; max-width: 420px; width: 100%; box-shadow: var(--shadow-sm); }
      .rp-logo { height: 44px; width: auto; display: block; }
      .rp-card h1 { font-size: 1.4rem; margin: 16px 0 6px; }
      .rp-card p.sub { color: var(--ink-3); font-size: 14px; margin: 0 0 22px; line-height: 1.5; }
      .rp-field { margin-bottom: 14px; }
      .rp-field label { display: block; font-size: 13px; font-weight: 600; color: var(--navy-900); margin-bottom: 6px; }
      .rp-field input { width: 100%; padding: 10px 12px; border: 1px solid var(--line); border-radius: 9px; font: inherit; }
      .rp-field input:focus { outline: 2px solid var(--navy-700); outline-offset: 1px; }
      .rp-btn { width: 100%; }
      .rp-msg { font-size: 13px; margin-top: 12px; line-height: 1.5; }
      .rp-msg.err { color: #dc2626; }
      .rp-msg.ok { color: #15803d; }
    </style>
  </head>
  <body>
    <main class="rp-shell">
      <div class="rp-card">
        <Img class="rp-logo" src="/images/logo.webp" alt="BdMSO" loading="eager" fetchpriority="high" />
        <h1>Set a new password</h1>
        <p class="sub">Choose a new password for your BdMSO guardian account.</p>
        <form id="rp-form">
          <div class="rp-field">
            <label for="rp-pw">New password</label>
            <input type="password" id="rp-pw" autocomplete="new-password" placeholder="At least 8 characters" required />
          </div>
          <div class="rp-field">
            <label for="rp-pw2">Confirm password</label>
            <input type="password" id="rp-pw2" autocomplete="new-password" placeholder="Re-enter password" required />
          </div>
          <button type="submit" class="btn btn-primary rp-btn" id="rp-submit">Update password</button>
        </form>
        <div class="rp-msg" id="rp-msg"></div>
      </div>
    </main>
    <script is:inline>
      (function () {
        var token = new URLSearchParams(location.search).get('token') || '';
        var form = document.getElementById('rp-form');
        var msg = document.getElementById('rp-msg');
        var submit = document.getElementById('rp-submit');

        function show(text, kind) { msg.textContent = text; msg.className = 'rp-msg ' + (kind || ''); }

        if (!token) {
          form.style.display = 'none';
          show('This reset link is invalid or incomplete. Please request a new one from the sign-in page.', 'err');
          return;
        }

        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          var pw = document.getElementById('rp-pw').value;
          var pw2 = document.getElementById('rp-pw2').value;
          if (pw.length < 8) { show('Password must be at least 8 characters.', 'err'); return; }
          if (pw !== pw2) { show('The two passwords do not match.', 'err'); return; }
          submit.disabled = true;
          submit.textContent = 'Updating…';
          show('', '');
          try {
            var res = await fetch('/api/reset-password', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ token: token, password: pw }),
            });
            var data = await res.json().catch(function () { return {}; });
            if (!res.ok) throw new Error(data.error || 'Could not reset the password.');
            form.style.display = 'none';
            show('Your password has been updated. You can now sign in with your new password.', 'ok');
            var a = document.createElement('a');
            a.href = '/dashboard';
            a.className = 'btn btn-primary rp-btn';
            a.style.marginTop = '14px';
            a.textContent = 'Go to sign in';
            msg.parentNode.appendChild(a);
          } catch (err) {
            show(err.message, 'err');
            submit.disabled = false;
            submit.textContent = 'Update password';
          }
        });
      })();
    </script>
  </body>
</html>
