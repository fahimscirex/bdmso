---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import Img from "../../components/Img.astro";
import { deriveRegState } from "../../lib/regState.js";
import { optimizedAbsolute } from "../../lib/ogImage";
import { relatedTo } from "../../lib/related.js";

const SITE = "https://bdmso.org";

export async function getStaticPaths() {
  const programs = await getCollection("programs");
  return programs
    // hidden: no public page at all.
    .filter((p) => !p.data.hidden)
    .map((program) => ({ params: { slug: program.id }, props: { program } }));
}

const { program } = Astro.props;
const p = program.data;
const slug = program.id;
const { Content } = await render(program);

const url = `${SITE}/programs/${slug}`;
const image = p.image
  ? (p.image.startsWith("http") ? p.image : `${SITE}${p.image.startsWith("/") ? p.image : `/${p.image}`}`)
  : `${SITE}/images/logo.webp`;
const metaDesc = p.metaDescription || p.tagline || "";
// Avoid "BdMSO X - BdMSO" double-branding when the title already leads "BdMSO".
const startsWithBrand = /^BdMSO\b/i.test(p.title);
const baseTitle = startsWithBrand ? p.title : `${p.title} - BdMSO`;
// Short brand-led titles ("BdMSO Mock Test") waste SERP space; append the
// audience (class level) for a descriptive, keyword-bearing title. Titles that
// already end "- BdMSO" keep their structure (brand stays last).
const pageTitle = startsWithBrand && baseTitle.length < 32 && p.audience ? `${baseTitle} - ${p.audience}` : baseTitle;

const isExternal = /^https?:/.test(p.register_url || "");
const todayISO = new Date().toISOString().slice(0, 10);
const regState = deriveRegState(p.yearRound === true, p.registrationStarts, p.registrationEnds, todayISO);
const regOpen = regState === "open";
const closedBoxStyle =
  "text-align:center;padding:14px;border-radius:12px;background:var(--bg-alt,#f1f3f7);color:var(--ink-3);font-weight:700;font-size:14px;";

// Course schema; add hasCourseInstance when concrete dates exist.
const fmt = (p.format || "").toLowerCase();
const mode = /online/.test(fmt) && !/on-site|onsite|offline/.test(fmt)
  ? "Online"
  : (/on-site|onsite|offline|maslab|residential/.test(fmt) ? "Onsite" : "Blended");
let courseInstance: Record<string, unknown> | null = null;
if (p.startsOn || p.endsOn) {
  courseInstance = { "@type": "CourseInstance", courseMode: mode };
  if (p.startsOn) courseInstance.startDate = p.startsOn;
  if (p.endsOn) courseInstance.endDate = p.endsOn;
  if (mode !== "Online") {
    courseInstance.location = { "@type": "Place", name: "MASLab, Dhaka", address: { "@type": "PostalAddress", addressCountry: "BD" } };
  }
  if (typeof p.feeAmount === "number") {
    courseInstance.offers = { "@type": "Offer", price: String(p.feeAmount), priceCurrency: "BDT", url, availability: "https://schema.org/InStock", category: "Paid" };
  }
}
const courseSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: p.title,
  description: metaDesc,
  url,
  image: await optimizedAbsolute(image),
  provider: { "@type": "EducationalOrganization", name: "Bangladesh Mathematics & Science Olympiad", url: SITE },
};
if (courseInstance) courseSchema.hasCourseInstance = courseInstance;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Programs", item: `${SITE}/programs` },
    { "@type": "ListItem", position: 3, name: p.title, item: url },
  ],
};

// Related reading: keyword overlap between this program and the blog (neither
// has explicit tags). Only strong matches link - see lib/related.js.
const relatedPosts = relatedTo(
  { title: p.title, slug },
  (await getCollection("blog")).map((post) => ({
    title: post.data.title, slug: post.data.slug, url: `/posts/${post.data.slug}`, desc: post.data.excerpt,
  })),
);
---

<BaseLayout title={pageTitle} description={metaDesc} page="programs" canonical={url} image={image} jsonLd={[courseSchema, breadcrumb]}>
    <section class="pd-hero"><div class="container">
      <div class="pd-topbar">
        <a class="pd-back" href="/programs">All programs</a>
        <span class="eyebrow">{p.eyebrow || "Program"}</span>
      </div>
      <h1>{p.title}</h1>
      <p class="lede">{p.tagline || p.metaDescription}</p>
    </div></section>

    <section class="container pd-wrap">
      <div class="pd-grid">
        <article class="pd-main">
          {p.image && <Img class="cover" src={p.image} alt={p.title} widths={[400, 800, 1200]} sizes="(max-width: 800px) 100vw, 720px" loading="eager" fetchpriority="high" />}

          {/* Main content is the markdown body - edit programs/<slug>.md, not JSON blocks. */}
          <Content />
        </article>

        <aside class="pd-side">
          <div class="pd-card">
            <div class="pd-price">{p.price || (typeof p.feeAmount === "number" ? `৳ ${p.feeAmount.toLocaleString("en-BD")}` : "")}</div>
            {p.schedule && <p class="pd-schedule">{p.schedule}</p>}
            {regOpen ? (
              <a
                class="btn btn-primary btn-lg pd-cta"
                id="pd-cta"
                href={p.register_url || `/registration?program=${slug}`}
                {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}
                data-reg-starts={p.registrationStarts}
                data-reg-ends={p.registrationEnds}
                data-year-round={p.yearRound ? "true" : undefined}
              >{p.register_label || "Register"} →</a>
            ) : (
              <div class="pd-cta" style={closedBoxStyle}>Registration closed</div>
            )}
            <div class="pd-facts">
              {p.audience && <div class="pd-fact"><div class="k">Who it's for</div><div class="v">{p.audience}</div></div>}
              {p.duration && <div class="pd-fact"><div class="k">Duration</div><div class="v">{p.duration}</div></div>}
              {p.format && <div class="pd-fact"><div class="k">Format</div><div class="v">{p.format}</div></div>}
              {p.outcome && <div class="pd-fact"><div class="k">Outcome</div><div class="v">{p.outcome}</div></div>}
            </div>
          </div>

          {regOpen && (
            <div class="pd-card pd-warning">
              <div class="t">⚠ Registration isn't complete until payment is confirmed</div>
              <div class="b">Submitting the registration form alone does not enroll your child. You'll need to complete payment from your dashboard to receive a BdMSO ID and access program resources.</div>
            </div>
          )}
        </aside>
      </div>
    </section>

    <RelatedContent
      heading="Related reading"
      items={relatedPosts.map((r) => ({ kicker: "Blog", title: r.title, desc: r.desc, url: r.url }))}
    />

  <script is:inline>
    // Downgrade the CTA to "opens on…/closed" based on the registration window.
    // Kept client-side so static pages never go stale. Canonical rule (copy of
    // deriveRegState): year-round programs are always open; otherwise derive
    // from the date window.
    (function () {
      var c = document.getElementById("pd-cta");
      if (!c) return;
      var t = new Date().toISOString().slice(0, 10);
      var s = c.dataset.regStarts, e = c.dataset.regEnds, m = "";
      function deriveRegState(yearRound, starts, ends, today) {
        if (yearRound) return "open";
        if (starts && today < starts) return "upcoming";
        if (ends && today > ends) return "closed";
        if (starts || ends) return "open";
        return "closed";
      }
      var state = deriveRegState(c.dataset.yearRound === "true", s, e, t);
      if (state === "upcoming") {
        m = "Registration opens " + new Date(s).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
      } else if (state === "closed") {
        m = "Registration closed";
      }
      if (m) {
        var b = document.createElement("div");
        b.className = "pd-cta";
        b.style.cssText = "text-align:center;padding:14px;border-radius:12px;background:var(--bg-alt,#f1f3f7);color:var(--ink-3);font-weight:700;font-size:14px;";
        b.textContent = m;
        c.replaceWith(b);
      }
    })();
  </script>
</BaseLayout>
