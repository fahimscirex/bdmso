---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Something went wrong - BdMSO"
  description="An unexpected error occurred."
  page="500"
  canonical="https://bdmso.org/500"
  robots="noindex"
>
  <main>
    <section class="section" style="text-align:center; padding:96px 0;">
      <div class="container">
        <span class="eyebrow">Error 500</span>
        <h1 style="margin:14px 0 12px;">Something went wrong on our end.</h1>
        <p style="max-width:520px; margin:0 auto 28px; color:var(--ink-2);">
          An unexpected error stopped this page from loading. It is not your fault - please try again in a moment.
        </p>
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
          <a class="btn btn-gold btn-lg" href="/">Back to home</a>
          <a class="btn btn-ghost btn-lg" href="mailto:support@bdmso.org">Contact support</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
