    /* Cards row: interactive draggable marquee under the hero. The track is
       duplicated by JS so the second half fills the gap as the first scrolls
       off-screen. Auto-scroll runs via requestAnimationFrame; dragging
       pauses it and applies spring-like momentum on release. */
    .zh-cards {
      position: relative; padding: 0 0 72px; overflow: hidden;
      touch-action: pan-y;  /* let vertical scroll through, capture horizontal */
    }
    .zh-cards.dragging .zh-card { cursor: grabbing; transition: none; }  /* no lift on drag — it fights the swipe */
    .zh-cards::before, .zh-cards::after {
      content: ""; position: absolute; top: 0; bottom: 72px; width: 64px; z-index: 2; pointer-events: none;
    }
    .zh-cards::before { left: 0; background: linear-gradient(to right, var(--bg, #fff), rgba(255,255,255,0)); }
    .zh-cards::after { right: 0; background: linear-gradient(to left, var(--bg, #fff), rgba(255,255,255,0)); }
    .zh-cards-track {
      display: flex; width: max-content;
      padding: 8px 0 24px;
      will-change: transform;
    }
    .zh-card {
      flex: 0 0 auto; width: 380px;
      margin-right: 18px;
      display: flex; flex-direction: column;
      background: white;
      border: 1px solid var(--line);
      border-radius: 18px; overflow: hidden;
      text-decoration: none; color: var(--navy-900);
      box-shadow: 0 2px 8px rgba(11, 27, 63, 0.04);
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
      transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1),
                  border-color 200ms ease,
                  box-shadow 200ms ease;
    }
    @media (hover: hover) and (pointer: fine) {
      .zh-card:hover {
        transform: translateY(-3px);
        border-color: var(--navy-200, #cbd5e1);
        box-shadow: 0 10px 24px rgba(11, 27, 63, 0.10);
      }
    }
    .zh-card:active {
      transform: scale(0.97);
    }
    @media (prefers-reduced-motion: reduce) {
      .zh-cards-track { will-change: auto; }
    }
    .zh-card-head { padding: 16px 18px 12px; display: flex; align-items: center; gap: 10px; }
    .zh-card-dot {
      width: 12px; height: 12px; border-radius: 50%;
      background: #facc15;
      box-shadow: 0 0 0 3px rgba(250, 204, 21, 0.18);
      flex-shrink: 0;
    }
    .zh-card-label { font-size: 15px; font-weight: 700; color: var(--navy-900); }
    .zh-card-media {
      margin: 0 12px 14px; aspect-ratio: 16/9;
      border-radius: 12px; overflow: hidden;
    }
    .zh-card-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    @media (max-width: 700px) {
