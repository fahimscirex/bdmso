---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { deriveRegState } from "../lib/regState.js";
import Img from "../components/Img.astro";
import { optimizedAbsolute } from "../lib/ogImage";
import { fmtPress } from "../lib/fmtPress";

const title = "BdMSO - Bangladesh Mathematics and Science Olympiad | IMSO Qualifier";
const description =
  "Official qualifying platform to select primary school students to represent Bangladesh at the International Mathematics and Science Olympiad (IMSO).";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    name: "Bangladesh Mathematics and Science Olympiad",
    alternateName: "BdMSO",
    url: "https://bdmso.org",
    logo: await optimizedAbsolute("https://bdmso.org/images/logo.webp"),
    description:
      "A platform dedicated to identifying and nurturing early age STEM talent across Bangladesh.",
    parentOrganization: [
      { "@type": "Organization", name: "Bangladesh Open Source Network", url: "https://bdosn.org" },
      { "@type": "Organization", name: "Society for the Popularization of Science, Bangladesh", url: "https://spsb.org" },
    ],
    contactPoint: {
      "@type": "ContactPoint",
      email: "support@bdmso.org",
      contactType: "customer support",
    },
    sameAs: [
      "https://facebook.com/imsobd",
      "https://www.youtube.com/@BdMSO25",
      "https://www.instagram.com/bdmso_/",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "BdMSO 2026 National Round",
    startDate: "2026-06-15",
    // Single-day exam held simultaneously across regional venues (see the
    // national-olympiad program), so the event ends on the same day.
    endDate: "2026-06-15",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
      "@type": "Place",
      name: "Multiple regional venues, Bangladesh",
      address: { "@type": "PostalAddress", addressCountry: "BD" },
    },
    image: await optimizedAbsolute("https://bdmso.org/images/national-round-winners.webp"),
    description:
      "BdMSO 2026 National Round - the official qualifying olympiad for primary-school students competing for the Bangladesh team at IMSO 2026.",
    organizer: { "@type": "Organization", name: "BdMSO", url: "https://bdmso.org" },
    // Real entry fee + registration window from the national-olympiad program.
    offers: {
      "@type": "Offer",
      price: "1000",
      priceCurrency: "BDT",
      availability: "https://schema.org/InStock",
      validThrough: "2026-06-30",
      url: "https://bdmso.org/registration?program=national-olympiad",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "23rd International Mathematics and Science Olympiad (IMSO 2026)",
    startDate: "2026-10-01",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
      "@type": "Place",
      name: "Indonesia",
      address: { "@type": "PostalAddress", addressCountry: "ID" },
    },
    description:
      "23rd IMSO - Bangladesh sends a 6+6 delegation of primary-school students selected through the BdMSO qualifying pathway.",
    organizer: { "@type": "Organization", name: "International Mathematics and Science Olympiad" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Who can participate in BdMSO?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "BdMSO is open to primary-school students in Bangladesh who are 13 or younger (born after 1 October 2013) and enrolled in Grade 6 or lower as of 1 October 2026.",
        },
      },
      {
        "@type": "Question",
        name: "My child is in Grade 6 on the National Curriculum - are they eligible?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. If your child is in Grade 6 during the registration period they will still be in Grade 6 on 1 October 2026, so they are eligible.",
        },
      },
      {
        "@type": "Question",
        name: "My child follows the British Curriculum and is promoted to Grade 7 in mid-2026 - are they eligible?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. Students promoted to Grade 7 in July or August 2026 are not eligible, even if they were in Grade 6 during the registration period, because eligibility is governed by the 1 October 2026 cutoff.",
        },
      },
    ],
  },
];

// Program cards rendered server-side (mirrors home.js renderPrograms):
// take programs with a home_order, drop hidden ones, sort by home_order,
// and derive the open/upcoming/closed badge with home.js's cardState logic.
const programs = (await getCollection("programs"))
  .filter((p) => p.data.home_order && !p.data.hidden)
  .sort((a, b) => String(a.data.home_order).localeCompare(String(b.data.home_order)));

// News & Announcements = the 4 most recent blog posts, server-rendered from the
// blog collection (replaces home.js fetching /posts/index.json).
const news = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

// Press collage = the first 6 published press mentions (featured first, then
// sort order - already ordered by the materializer). Server-rendered so it is
// crawlable; home.js no longer fills this. CSS uppercases the date label.
// Hall of Fame slider photos (ordered by the materializer). Server-rendered so
// crawlers see them; home.js keeps the slider interaction (arrows/dots/timer).
const famePhotos = await getCollection("halloffame");

const pressItems = (await getCollection("press")).slice(0, 6);

// Start-guide tiers (mirrors home.js renderGuide): program titles by slug,
// server-rendered from the programs collection so the homepage no longer
// fetches programs-detail.json at all.
const titleBySlug = new Map((await getCollection("programs")).map((p) => [p.id, p.data.title]));
const GUIDE: Record<string, string[]> = {
  beginner: ["stem-foundation", "lab-day", "stem-masterclass"],
  advance: ["bdmso-preparatory", "stem-masterclass", "mock-test"],
  open: ["summer-camp", "winter-camp", "exchange-program"],
};

const todayISO = new Date().toISOString().slice(0, 10);
// State is derived from the date window plus the year-round flag (always open).
const cardState = (p: { yearRound?: boolean; registrationStarts?: string; registrationEnds?: string }) =>
  deriveRegState(p.yearRound === true, p.registrationStarts, p.registrationEnds, todayISO);

// Top announcement banner, derived from REAL registration state (no hardcoded
// claim). Announce whatever is open now; if nothing is open, point at the
// soonest upcoming intake; if neither, the banner is not rendered at all.
const stripBd = (t: string) => t.replace(/^BdMSO\s+/i, "");
const joinNames = (names: string[]) =>
  names.length === 1 ? names[0]
  : names.length === 2 ? `${names[0]} and ${names[1]}`
  : names.length === 3 ? `${names[0]}, ${names[1]} and ${names[2]}`
  : `${names[0]}, ${names[1]} and ${names.length - 2} more`;
const fmtDate = (iso?: string) =>
  iso ? new Date(iso).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }) : "";

const openProgs = programs.filter((p) => cardState(p.data) === "open");
const upcomingProgs = programs
  .filter((p) => cardState(p.data) === "upcoming" && p.data.registrationStarts)
  .sort((a, b) => String(a.data.registrationStarts).localeCompare(String(b.data.registrationStarts)));

let bannerDesktop = "";
let bannerMobile = "";
if (openProgs.length) {
  bannerDesktop = `BdMSO 2026 - Registration is open for ${joinNames(openProgs.map((p) => stripBd(p.data.title)))}.`;
  bannerMobile = "Registration open for BdMSO 2026.";
} else if (upcomingProgs.length) {
  const next = upcomingProgs[0];
  bannerDesktop = `BdMSO 2026 - Registration for ${stripBd(next.data.title)} opens ${fmtDate(next.data.registrationStarts)}.`;
  bannerMobile = "Registration opening soon.";
}
const showBanner = bannerDesktop !== "";
---

<BaseLayout
  title={title}
  description={description}
  page="home"
  canonical="https://bdmso.org/"
  image="https://bdmso.org/images/group-winner.webp"
  imageAlt="BdMSO olympiad winners celebrating together as a group"
  jsonLd={jsonLd}
>
  <style is:global slot="head">
    /* ---------- Home-specific ---------- */

    /* HERO */
    .hero {
      position: relative;
      overflow: hidden;
      padding: 72px 0 88px;
      background:
        radial-gradient(1100px 520px at 85% 10%, var(--glow-gold-hero), transparent 60%),
        radial-gradient(800px 500px at 5% 100%, var(--glow-teal-hero), transparent 60%),
        linear-gradient(180deg, oklch(0.98 0.01 250), oklch(0.96 0.015 245));
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .hero-copy .eyebrow { margin-bottom: 28px; }
    .hero h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 1.08;
      margin-bottom: 28px;
      text-wrap: balance;
    }
    .hero h1 .accent {
      background: linear-gradient(100deg, var(--navy-800) 0%, var(--teal-600) 60%, var(--gold-600) 100%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .hero-sub {
      font-size: 1.15rem;
      color: var(--ink-2);
      margin-bottom: 32px;
      max-width: 560px;
    }
    .hero-facts {
      display: flex; flex-direction: column; gap: 10px;
      margin: 22px 0 30px;
    }
    .hero-facts li {
      display: flex; gap: 10px; align-items: flex-start;
      color: var(--ink-2);
      font-size: 14.5px;
    }
    .hero-facts li::before {
      content: ""; margin-top: 7px; flex-shrink: 0;
      width: 6px; height: 6px; border-radius: 50%; background: var(--gold-500);
      box-shadow: 0 0 0 4px var(--glow-gold);
    }
    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

    .hero-visual {
      position: relative;
      width: 100%;
      max-width: 560px;
      justify-self: end;
      aspect-ratio: 4/3;
      border-radius: var(--r-xl);
      overflow: visible;
    }
    .hero-visual img {
      position: absolute; inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-lg);
    }
    .hero-badge {
      position: absolute;
      background: white;
      border-radius: 18px;
      padding: 16px 20px;
      box-shadow: var(--shadow-lg);
      display: flex; align-items: center; gap: 14px;
      border: 1px solid var(--line-2);
    }
    .hero-badge .num {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 700;
      color: var(--navy-900);
      line-height: 1;
    }
    .hero-badge .lbl { font-size: 12px; color: var(--ink-3); line-height: 1.3; max-width: 120px; }
    .hero-badge.top { top: -22px; left: -28px; }
    .hero-badge.bot { bottom: -22px; right: -28px; background: var(--navy-900); color: white; border: none; }
    .hero-badge.bot .num { color: var(--gold-500); }
    .hero-badge.bot .lbl { color: var(--on-dark-3); }

    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; gap: 48px; }
      .hero-copy {
        order: 1;
        text-align: center;
      }
      .hero-sub,
      .hero-facts {
        margin-left: auto;
        margin-right: auto;
      }
      .hero-cta {
        justify-content: center;
      }
      .hero-visual {
        order: 2;
        width: 100%;
        max-width: none;
        justify-self: stretch;
        margin: 0 0 8px;
      }
      .hero-badge.top { left: 0; }
      .hero-badge.bot { right: 0; }
    }
    @media (max-width: 520px) {
      .hero {
        padding: 40px 0 64px;
      }
      .hero-grid {
        gap: 28px;
      }
      .hero h1 {
        font-size: clamp(2rem, 9vw, 2.8rem);
      }
      .hero-sub {
        font-size: 1rem;
      }
      .hero-facts {
        gap: 14px;
        max-width: 320px;
        margin: 18px auto 26px;
      }
      .hero-facts li {
        display: grid;
        grid-template-columns: 14px 1fr;
        gap: 12px;
        align-items: start;
        text-align: left;
        font-size: 14px;
        line-height: 1.5;
      }
      .hero-facts li::before {
        margin-top: 8px;
      }
      .hero-cta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        width: 100%;
        max-width: 320px;
        margin: 0 auto;
      }
      .hero-cta .btn {
        width: 100%;
        min-height: 48px;
        padding: 12px 14px;
      }
      .hero-cta .btn:nth-child(3) {
        grid-column: 1 / -1;
        width: 100%;
      }
      .hero-visual {
        width: 100%;
        max-width: none;
        margin-top: 6px;
      }
      .hero-badge {
        width: 184px;
        min-height: 64px;
        padding: 12px 14px;
        gap: 10px;
      }
      .hero-badge .num { font-size: 22px; }
      .hero-badge .lbl {
        font-size: 11px;
        max-width: none;
      }
      .hero-badge.top {
        top: -14px;
      }
      .hero-badge.bot {
        bottom: -14px;
      }
    }

    /* TRUST BAR */
    .trust-bar {
      background: var(--navy-900);
      color: white;
      padding: 40px 0;
      position: relative;
    }
    .trust-bar::before {
      content: "";
      position: absolute; inset: 0;
      background: radial-gradient(600px 200px at 85% 50%, var(--glow-gold), transparent 60%);
      pointer-events: none;
    }
    .trust-head { text-align: center; font-size: 13px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--gold-on-dark-2); margin-bottom: 24px; font-weight: 600; }
    .trust-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 18px; position: relative; }
    .trust-item {
      text-align: center;
      padding: 18px 12px;
      border-left: 1px solid var(--navy-border-dk);
    }
    .trust-item:first-child { border-left: none; }
    .trust-item .big {
      font-family: var(--font-display);
      font-size: clamp(1.7rem, 2.6vw, 2.4rem);
      font-weight: 700;
      color: white;
      line-height: 1;
      margin-bottom: 6px;
    }
    .trust-item .big .unit { color: var(--gold-500); }
    .trust-item .lbl { font-size: 13px; color: var(--on-dark-2); }
    @media (max-width: 900px) {
      .trust-grid { grid-template-columns: repeat(2, 1fr); }
      .trust-item { border-left: none; border-top: 1px solid var(--navy-border-dk); padding-top: 18px; }
      .trust-item:first-child, .trust-item:nth-child(2) { border-top: none; padding-top: 0; }
      /* If the last item is alone on its row, center it across both columns. */
      .trust-item:last-child:nth-child(odd) { grid-column: 1 / -1; }
    }

    /* ABOUT */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 56px;
      align-items: center;
    }
    .about-img { aspect-ratio: 4/3; border-radius: var(--r-lg); overflow: hidden; position: relative; }
    .about-img .ph { position: absolute; inset: 0; border-radius: var(--r-lg); font-size: 13px; }
    .about-img .tag {
      position: absolute; bottom: 18px; left: 18px;
      background: white; padding: 10px 14px; border-radius: 999px; font-size: 13px; font-weight: 600; color: var(--navy-900);
      box-shadow: var(--shadow); display: flex; gap: 8px; align-items: center;
    }
    .about-img .tag::before {
      content: ""; width: 8px; height: 8px; background: var(--gold-500); border-radius: 50%;
      box-shadow: 0 0 0 4px var(--glow-gold-md);
    }
    .about-text p { margin-bottom: 16px; font-size: 1.02rem; }
    .about-highlights {
      display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 26px;
    }
    .about-highlights .item {
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: var(--r);
      background: white;
    }
    .about-highlights .item .n { font-family: var(--font-display); font-size: 1.4rem; color: var(--navy-900); font-weight: 700; line-height: 1; margin-bottom: 6px; }
    .about-highlights .item .t { font-size: 13px; color: var(--ink-3); line-height: 1.4; }

    @media (max-width: 800px) {
      .about-grid { grid-template-columns: 1fr; gap: 32px; }
    }

    /* ROAD TO IMSO */
    .road {
      background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-deep) 100%);
      color: white;
      padding: 96px 0;
      position: relative;
      overflow: hidden;
    }
    .road::before {
      content: "";
      position: absolute; inset: 0;
      background:
        radial-gradient(500px 400px at 90% 0%, var(--glow-gold-sm), transparent 55%),
        radial-gradient(500px 400px at 5% 100%, var(--glow-teal), transparent 55%);
      pointer-events: none;
    }
    .road h2 { color: white; }
    .road .eyebrow { background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); }
    .road .section-head p { color: var(--on-dark-3); }

    .steps {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 12px;
      position: relative;
      counter-reset: step;
    }
    .steps::before {
      content: "";
      position: absolute;
      top: 32px; left: 5%; right: 5%;
      height: 2px;
      background: linear-gradient(90deg, var(--navy-lift-dk), var(--gold-500), var(--teal-600));
      opacity: 0.5;
      z-index: 0;
    }
    .step {
      position: relative;
      text-align: center;
      z-index: 1;
      padding: 0 4px;
    }
    .step-num {
      width: 64px; height: 64px;
      border-radius: 50%;
      margin: 0 auto 16px;
      display: grid; place-items: center;
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 700;
      color: white;
      background: var(--navy-800);
      border: 2px solid var(--navy-ring);
      position: relative;
      transition: transform 0.25s;
    }
    .step:hover .step-num { transform: scale(1.08); }
    /* Step 1 is the current ongoing step - gold with a live "heartbeat" pulse. */
    .step:nth-child(1) .step-num {
      background: var(--gold-600); border-color: var(--gold-500); color: var(--navy-900);
      animation: step-current 1.8s ease-in-out infinite;
    }
    @keyframes step-current {
      0%, 100% { box-shadow: 0 0 0 0 rgba(212, 160, 23, 0.5); }
      70%      { box-shadow: 0 0 0 13px rgba(212, 160, 23, 0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .step:nth-child(1) .step-num { animation: none; }
    }
    .step-name { font-weight: 600; color: white; font-size: 14px; margin-bottom: 4px; line-height: 1.25; }
    .step-date {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--gold-on-dark-3);
      letter-spacing: 0.03em;
    }
    @media (max-width: 900px) {
      .steps { grid-template-columns: repeat(2, 1fr); gap: 24px 12px; }
      .steps::before { display: none; }
      .step { text-align: left; display: grid; grid-template-columns: 48px 1fr; gap: 12px; align-items: center; }
      .step-num { margin: 0; width: 48px; height: 48px; font-size: 17px; }
    }
    @media (max-width: 520px) {
      .road {
        padding: 72px 0;
      }
      .road .section-head {
        margin-bottom: 36px;
      }
      .road .section-head p {
        max-width: 320px;
        margin: 0 auto;
      }
      .steps {
        position: relative;
        grid-template-columns: 1fr;
        gap: 18px;
        padding-left: 4px;
      }
      .steps::before {
        display: none;
      }
      .step {
        position: relative;
        grid-template-columns: 56px 1fr;
        grid-template-areas:
          "num name"
          "num date";
        column-gap: 14px;
        row-gap: 2px;
        align-items: start;
        padding: 0 0 0 2px;
      }
      .step::after {
        content: "";
        position: absolute;
        left: 29px;
        top: 56px;
        width: 2px;
        height: calc(100% - 38px);
        background: linear-gradient(180deg, var(--navy-lift-dk), var(--teal-600), var(--gold-500));
        opacity: 0.7;
      }
      .step:last-child::after {
        display: none;
      }
      .step-num {
        grid-area: num;
        width: 56px;
        height: 56px;
        font-size: 20px;
        position: relative;
        z-index: 1;
        align-self: start;
      }
      .step-name {
        grid-area: name;
        font-size: 15px;
        margin: 4px 0 2px;
        align-self: end;
      }
      .step-date {
        grid-area: date;
        display: block;
        font-size: 12px;
        line-height: 1.5;
        letter-spacing: 0.08em;
        margin: 0;
        align-self: start;
      }
    }

    /* HALL OF FAME */
    .fame-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 18px;
      margin-bottom: 28px;
    }
    .fame-card {
      background: white;
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
      padding: 16px;
      transition: transform 0.25s, box-shadow 0.25s;
      position: relative;
      overflow: hidden;
    }
    .fame-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
    .fame-card .photo { aspect-ratio: 4/5; border-radius: var(--r); position: relative; overflow: hidden; margin-bottom: 14px; }
    .fame-card .photo .ph { position: absolute; inset: 0; border-radius: var(--r); }
    .fame-card .medal {
      position: absolute; top: 12px; left: 12px;
      font-size: 11px; font-weight: 700;
      padding: 5px 10px; border-radius: 999px;
      letter-spacing: 0.04em;
    }
    .medal.gold { background: var(--gold-500); color: var(--navy-900); }
    .medal.silver { background: var(--medal-silver); color: var(--navy-900); }
    .medal.bronze { background: var(--medal-bronze); color: white; }
    .fame-card h4 { margin-bottom: 4px; font-size: 1.1rem; }
    .fame-card .meta { font-size: 13px; color: var(--ink-3); margin-bottom: 8px; }
    .fame-card .quote { font-size: 13.5px; color: var(--ink-2); font-style: italic; line-height: 1.5; }

    /* FAME SLIDER */
    .fame-slider { position: relative; margin-top: 28px; }
    .fame-slide-track { position: relative; aspect-ratio: 16/7; border-radius: var(--r-lg); overflow: hidden; margin-bottom: 18px; background: var(--bg-alt); }
    .fame-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.4s; }
    .fame-slide.active { opacity: 1; }
