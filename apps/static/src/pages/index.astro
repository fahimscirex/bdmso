  <script src="/js/home.js" defer is:inline></script>
  <script is:inline>
    (function() {
      const btn = document.getElementById('upcoming-events-btn');
      const modal = document.getElementById('upcoming-events-modal');
      if (btn && modal) {
        const open = () => { modal.hidden = false; document.body.style.overflow = 'hidden'; };
        const close = () => { modal.hidden = true; document.body.style.overflow = ''; };
        btn.addEventListener('click', open);
        modal.querySelectorAll('[data-ue-close]').forEach(el => el.addEventListener('click', close));
        document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) close(); });
      }

      // Top announcement banner - dismissible, remembered for the session.
      const banner = document.getElementById('top-banner');
      const bannerClose = document.getElementById('top-banner-close');
      if (banner && bannerClose) {
        document.body.classList.add('has-top-banner');
        const dismiss = () => {
          banner.hidden = true;
          document.body.classList.remove('has-top-banner');
          try { sessionStorage.setItem('top_banner_dismissed', '1'); } catch {}
        };
        if (sessionStorage.getItem('top_banner_dismissed') === '1') dismiss();
        bannerClose.addEventListener('click', dismiss);
      }

      // ── Interactive marquee row ────────────────────────────────────────
      // Auto-scrolls via rAF loop; hovers pause; drag with spring-
      // momentum release so a quick flick coasts farther than a slow
      // drag.  The track is duplicated and wraps seamlessly.
      // ── Emil-style constraints ────────────────────────────────────────
      // • spring decay, not linear deceleration (feels organic)
      // • momentum velocity clamped (avoid rocket-launch flicks)
      // • multi-touch guard, pointer capture outside bounds
      // • scale(0.97) on active (cards feel responsive to press)
      // • no animation for prefers-reduced-motion
      const cardsWrap = document.querySelector('.zh-cards');
      const trackEl   = document.getElementById('zh-cards-track');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (trackEl && cardsWrap) {
        // Duplicate track for seamless wrap.
        Array.from(trackEl.children).forEach(n => {
          const c = n.cloneNode(true);
          c.setAttribute('aria-hidden', 'true');
          c.setAttribute('tabindex', '-1');
          trackEl.appendChild(c);
        });

        let offset     = 0;
        let velocity   = 0;
        let autoSpeed  = prefersReducedMotion ? 0 : ('ontouchstart' in window ? 0.055 : 0.045);
        let rafId      = null;
        let lastTime   = 0;
        let hovered    = false;       // true while mouse is over the row
        let holdUntil  = 0;           // pause auto-scroll until this timestamp
        let justDragged = false;       // set on release, cleared when hold fires

        // Drag state.
        let dragging       = false;
        let dragStarted    = false;
        let dragStartX     = 0;
        let dragStartOff   = 0;
        let dragLastX      = 0;
        let dragLastTime   = 0;
        const DRAG_THRESH = 5;        // px — below this it's a tap, let click through

        const halfW = () => trackEl.scrollWidth / 2;

        const apply = () => {
          // Wrap offset into [0, halfW) – no visual jump because the two
          // halves are pixel-identical.
          const hw = halfW();
          while (offset >= hw) offset -= hw;
          while (offset < 0)    offset += hw;
          trackEl.style.transform = `translate3d(${-offset}px, 0, 0)`;
        };

        const clientX = (e) => e.touches ? e.touches[0].clientX : e.clientX;

        const onMove = (e) => {
          if (!dragStarted) return;
          const cx = clientX(e);
          // Only commit to dragging after the pointer moves past the
          // threshold. Below 5 px it's a tap — let the click through.
          if (!dragging && Math.abs(cx - dragStartX) < DRAG_THRESH) return;
          e.preventDefault();
          if (!dragging) { dragging = true; cardsWrap.classList.add('dragging'); }
          dragLastX    = cx;
          dragLastTime = performance.now();
          offset = dragStartOff + (dragStartX - cx);
          apply();
        };

        const onUp = (e) => {
          if (!dragStarted) return;
          dragStarted = false;
          const wasDragging = dragging;
          dragging = false;
          if (wasDragging) cardsWrap.classList.remove('dragging');

          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup',   onUp);
          document.removeEventListener('touchmove', onMove);
          document.removeEventListener('touchend',  onUp);
          document.removeEventListener('touchcancel', onUp);

          if (!wasDragging) return; // tap, no momentum

          // Spring-momentum release — velocity from the last ~50 ms of drag
          // movement gives the coast distance. Clamp so a violent flick
          // doesn't launch past the entire row.
          const dt  = Math.max(performance.now() - dragLastTime, 1);
          const dx  = dragStartX - dragLastX;
          velocity  = dx / dt * 0.5;
          velocity  = Math.max(-0.8, Math.min(0.8, velocity));
          lastTime  = performance.now();
          justDragged = true;
        };

        const onDown = (e) => {
          if (dragStarted || (e.touches && e.touches.length > 1)) return;
          // Only cards are interactive — empty space between cards passes
          // through for vertical scrolling on mobile.
          if (!e.target.closest('.zh-card')) return;
          dragStarted   = true;
          dragStartX    = clientX(e);
          dragStartOff  = offset;
          dragLastX     = dragStartX;
          dragLastTime  = performance.now();
          velocity      = 0;
          holdUntil     = 0;

          if (e.type === 'mousedown') {
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup',   onUp);
          } else {
            document.addEventListener('touchmove', onMove, { passive: false });
            document.addEventListener('touchend',  onUp);
          }
        };

        cardsWrap.addEventListener('mousedown',  onDown);
        cardsWrap.addEventListener('touchstart', onDown, { passive: false });
        cardsWrap.addEventListener('mouseenter', () => { hovered = true;  holdUntil = 0; });
        cardsWrap.addEventListener('mouseleave', () => { hovered = false; holdUntil = performance.now() + 1200; });

        // rAF loop — auto-scrolls and applies momentum decay.
        const tick = (ts) => {
          if (!lastTime) lastTime = ts;
          const dt = Math.min(ts - lastTime, 50);
          lastTime = ts;

          if (!dragging) {
            if (hovered) {
              lastTime = ts;
            } else if (Math.abs(velocity) > 0.005) {
              velocity *= Math.exp(-5.5 * dt * 0.001);
              offset   += velocity * dt;
            } else if (justDragged || holdUntil) {
              // Hold: start the pause when velocity first settles after
              // a drag release, or continue an existing hold.
              if (justDragged && !holdUntil) holdUntil = ts + 800;
              justDragged = false;
              velocity = 0;
              if (ts < holdUntil) { lastTime = ts; } else { holdUntil = 0; offset += autoSpeed * dt; }
            } else {
              holdUntil = 0;
              velocity = 0;
              offset   += autoSpeed * dt;
            }
            apply();
          }

          rafId = requestAnimationFrame(tick);
        };

        rafId = requestAnimationFrame(tick);

        // bfcache restore (browser Back button) freezes the marquee: the
        // rAF loop is killed on navigation and never resumes, and stale
        // state from before nav (hovered=true if the cursor was over a
        // card when clicked, lingering document drag listeners) can stay
        // attached. Reset everything and kick the loop back on pageshow
        // with event.persisted - which only fires on bfcache restore.
        window.addEventListener('pageshow', (e) => {
          if (!e.persisted) return;
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup',   onUp);
          document.removeEventListener('touchmove', onMove);
          document.removeEventListener('touchend',  onUp);
          document.removeEventListener('touchcancel', onUp);
          cardsWrap.classList.remove('dragging');
          hovered = false; holdUntil = 0; velocity = 0;
          dragStarted = false; dragging = false; justDragged = false;
          lastTime = 0;
          if (rafId) cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(tick);
        });

        // Tab visibility: stop the rAF loop entirely when the tab is
        // hidden so we don't spin the GPU on a row nobody is looking at,
        // and restart cleanly when it comes back (lastTime reset prevents
        // a giant first-frame dt that would otherwise jump the marquee).
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') {
            if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
          } else if (!rafId) {
            lastTime = 0;
            rafId = requestAnimationFrame(tick);
          }
        });
      }
    })();
  </script>
</BaseLayout>
