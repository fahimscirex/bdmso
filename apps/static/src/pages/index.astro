    }

    .ue-modal[hidden] { display: none; }
    .ue-modal {
      position: fixed; inset: 0; z-index: 1000; display: flex;
      align-items: center; justify-content: center; padding: 24px;
      transition: opacity var(--dur-ui) var(--ease-out);
    }
    @starting-style {
      .ue-modal { opacity: 0; }
    }
    .ue-backdrop { position: absolute; inset: 0; background: rgba(11, 27, 63, 0.72); backdrop-filter: blur(2px); cursor: pointer; }
    .ue-dialog {
      position: relative; background: white; border-radius: 16px;
      padding: 18px 22px; max-width: min(92vw, 980px); max-height: 92vh;
      box-shadow: 0 24px 64px rgba(0,0,0,0.35);
      display: flex; flex-direction: column; overflow: auto;
      transition: transform var(--dur-modal) var(--ease-out);
    }
    @starting-style {
      .ue-dialog { transform: scale(0.96); }
    }
    .ue-title { font-family: var(--font-display); color: var(--navy-900); margin: 0 0 10px; font-size: 1.25rem; flex: 0 0 auto; }
    /* picture{display:contents} (global) promotes the <img> to a direct flex
       child here. Bound it to the viewport (92vh minus the dialog's title +
       padding) so the whole poster fits; the dialog also scrolls as a safety
       net on very short viewports. */
    .ue-dialog img { display: block; width: auto; max-width: 100%; max-height: calc(92vh - 96px); height: auto; border-radius: 10px; margin: 0 auto; }
    .ue-close {
