---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Img from "../components/Img.astro";
import { optimizedAbsolute } from "../lib/ogImage";

// Team members come from D1 (edited in the admin dashboard), materialized to the
// team content collection. Already ordered by section + sort_order.
const all = await getCollection("team");
const inSection = (s: string) => all.filter((m) => m.data.section === s);
const advisors = inSection("advisor");
const organizing = inSection("organizing");
const mentors = inSection("mentor");
const alumni = inSection("alumni");
const delegation = inSection("delegation");

// Always show the current year's tab (placeholder until announced) plus every
// year with a published delegation.
const currentYear = String(new Date().getFullYear());
const years = [...new Set([currentYear, ...delegation.map((m) => m.data.year).filter(Boolean)])]
  .sort((a, b) => b.localeCompare(a));
const delegFor = (year: string, subgroup: string) =>
  delegation.filter((m) => m.data.year === year && m.data.subgroup === subgroup);
// Per-year context line under the delegation heading (not editable - static copy).
const BLURBS: Record<string, string> = {
  "2026": "23rd IMSO · Indonesia, October 2026. The team will be selected after the National Round and Team Selection Test (TST).",
  "2025": "22nd IMSO · Albukhary International University, Kedah, Malaysia · Oct 5–9, 2025.",
};

const title = "BdMSO Team - Organizers, Mentors and IMSO Delegation";
const description =
  "Meet the people behind BdMSO - the 2026 and 2025 Bangladesh IMSO delegations, advisors, organizing team, mentors and volunteers driving primary-school STEM.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Bangladesh Mathematics and Science Olympiad",
    alternateName: "BdMSO",
    url: "https://bdmso.org",
    description:
      "Meet the 2026 and 2025 Bangladesh IMSO delegations, advisors, organizing team, mentors, and volunteers behind BdMSO.",
    logo: await optimizedAbsolute("https://bdmso.org/images/logo.webp"),
    member: [
      { "@type": "Person", name: "Munir Hasan", jobTitle: "Advisor, BdMSO and General Secretary, BdOSN" },
      { "@type": "Person", name: "Samin Yasar Ahmed", jobTitle: "Coordinator, BdMSO" },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  page="team"
  canonical="https://bdmso.org/team"
  image="https://bdmso.org/images/group-pre-international.webp"
  imageAlt="BdMSO team and students before an international olympiad"
  jsonLd={jsonLd}
>
  <style is:global slot="head">
    .page-head { background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy-page-dark) 100%); color: white; padding: 80px 0 100px; position: relative; overflow: hidden; }
    .page-head::before { content:""; position:absolute; inset:0; background: radial-gradient(600px 300px at 50% 100%, var(--glow-gold-sm), transparent 60%); }
    .page-head .eyebrow { background: var(--navy-surface-dk); color: var(--gold-on-dark); border-color: var(--navy-border-dk); margin-bottom: 18px; }
    .page-head h1 { color: white; max-width: 720px; margin: 0 0 12px; }
    .page-head p { color: var(--on-dark-2); max-width: 640px; margin: 0; font-size: 1.05rem; }

    .wrap { margin-top: -56px; position: relative; z-index: 2; padding-bottom: 96px; }
    .panel { background: white; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 32px; margin-bottom: 28px; }
    .panel-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 24px; flex-wrap: wrap; }

    .years { display: flex; gap: 4px; padding: 6px; background: var(--bg-alt); border-radius: 10px; }
    .years button { padding: 7px 14px; font-weight: 600; font-size: 13px; color: var(--ink-2); border-radius: 8px; flex: 1; text-align: center; }
    .years button.active { background: var(--navy-900); color: white; }

    .grid-6 { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }

    @media (max-width: 1000px) { .grid-6 { grid-template-columns: repeat(3, 1fr); } .grid-4 { grid-template-columns: repeat(2, 1fr); } .grid-3 { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .grid-6 { grid-template-columns: repeat(2, 1fr); } .grid-4, .grid-3 { grid-template-columns: 1fr; } }

    .person { text-align: center; }
    .person .pf { aspect-ratio: 4/5; border-radius: var(--r); margin-bottom: 10px; font-size: 11px; overflow: hidden; position: relative; }
    .person .pf img { transform: scale(1.18); transform-origin: center 30%; }
    .person .pf .ph { position: absolute; inset: 0; border-radius: var(--r); }
    .person .nm { font-weight: 700; color: var(--navy-900); font-size: 14px; line-height: 1.25; }
    .person .rl { font-size: 12px; color: var(--ink-3); margin-top: 2px; }

    .lead-band {
      display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
      grid-auto-rows: 1fr;
      margin-bottom: 24px;
    }
    .lead-card {
      padding: 22px; background: var(--navy-50); border-radius: var(--r-lg);
      display: flex; gap: 18px; align-items: center; border: 1px solid var(--navy-100);
    }
    .lead-card .pf { width: 84px; height: 84px; border-radius: 50%; flex-shrink: 0; margin: 0; aspect-ratio: 1; }
    .lead-card .role { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--navy-700); margin-bottom: 4px; }
    .lead-card .nm { font-size: 1.1rem; font-weight: 700; color: var(--navy-900); font-family: var(--font-display); }
    .lead-card .aff { font-size: 13px; color: var(--ink-3); margin-top: 2px; }
    @media (max-width: 700px) { .lead-band { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .years { width: 100%; } .panel { padding: 20px 16px; } .years button { padding: 7px 10px; } }

    .person .aff { font-size: 12px; color: var(--ink-3); margin-top: 4px; font-family: var(--font-mono); }

    /* Mentors & Volunteers carousel: every card rotates through the visible slots. */
    #mv-grid .person { transition: opacity 0.4s ease; }
    #mv-grid .person[data-mv-hidden] { display: none; }
  </style>

    <section class="page-head"><div class="container">
      <span class="eyebrow">The Minds Behind BdMSO</span>
      <h1>Our Team &amp; Delegation</h1>
      <p>A community of students, academics, mentors and volunteers - working year-round to take Bangladesh to the world stage.</p>
    </div></section>

    <section class="container wrap">

      <div class="panel">
        <div class="panel-head">
          <div><span class="eyebrow">Section 1</span><h2 style="margin-top:10px;">Bangladesh Team Delegation</h2><p id="delegation-blurb" style="margin:6px 0 0; max-width:520px;">{BLURBS[years[0]] || ""}</p></div>
          <div class="years" role="tablist">
            {years.map((y, i) => <button class={i === 0 ? "active" : ""} data-year={y}>{y}</button>)}
          </div>
        </div>

        {years.map((y, i) => {
          const math = delegFor(y, "Mathematics");
          const science = delegFor(y, "Science");
          const leadership = delegFor(y, "Leadership");
          const has = math.length + science.length + leadership.length > 0;
          return (
            <div class="year-panel" data-year={y} data-blurb={BLURBS[y] || ""} hidden={i !== 0}>
              {!has ? (
                <div style="padding:48px 24px; text-align:center; background:var(--bg-alt); border:1px dashed var(--line); border-radius:var(--r-lg);">
                  <div style="font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-3); margin-bottom:8px;">Not yet announced</div>
                  <h3 style="margin:0 0 8px; color:var(--navy-900);">Delegation will be published after TST</h3>
                  <p style="margin:0 auto; max-width:520px; color:var(--ink-2); font-size:14px;">The {y} Bangladesh delegation - 6 Mathematics + 6 Science students, 2 Tutors, and 1 Team Leader - will be announced once the National Round, Camp, and Team Selection Test are complete.</p>
                </div>
              ) : (
                <>
                  {math.length > 0 && (
                    <>
                      <h4 style="font-family:var(--font-sans); font-size:13px; text-transform:uppercase; letter-spacing:0.14em; color:var(--ink-3); margin:0 0 6px;">Mathematics Team · {math.length} Members</h4>
                      <p style="margin:0 0 14px; font-size:13px; color:var(--ink-2); font-style:italic;">Names are sorted alphabetically.</p>
                      <div class="grid-6">
                        {math.map((m) => (
                          <div class="person"><div class="pf"><Img src={m.data.image} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" alt={m.data.name} widths={[200, 400]} sizes="200px" /></div><div class="nm">{m.data.name}</div>{m.data.role && <div class="rl">{m.data.role}</div>}</div>
                        ))}
                      </div>
                    </>
                  )}
                  {science.length > 0 && (
                    <>
                      <h4 style="font-family:var(--font-sans); font-size:13px; text-transform:uppercase; letter-spacing:0.14em; color:var(--ink-3); margin:28px 0 6px;">Science Team · {science.length} Members</h4>
                      <p style="margin:0 0 14px; font-size:13px; color:var(--ink-2); font-style:italic;">Names are sorted alphabetically.</p>
                      <div class="grid-6">
                        {science.map((m) => (
                          <div class="person"><div class="pf"><Img src={m.data.image} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" alt={m.data.name} widths={[200, 400]} sizes="200px" /></div><div class="nm">{m.data.name}</div>{m.data.role && <div class="rl">{m.data.role}</div>}</div>
                        ))}
                      </div>
                    </>
                  )}
                  {leadership.length > 0 && (
                    <div class="lead-band" style="margin-top:28px;">
                      {leadership.map((m) => (
                        <div class="lead-card"><div class="pf" style="background:none;"><Img src={m.data.image} style="width:100%;height:100%;object-fit:cover;border-radius:50%;" alt={m.data.name} widths={[168]} sizes="84px" /></div><div>{m.data.role && <div class="role">{m.data.role}</div>}<div class="nm">{m.data.name}</div>{m.data.affiliation && <div class="aff">{m.data.affiliation}</div>}</div></div>
                      ))}
                    </div>
                  )}
                </>
              )}
            </div>
          );
        })}
      </div>

      <div class="panel advisor">
        <div class="panel-head"><div><span class="eyebrow">Section 2</span><h2 style="margin-top:10px;">Advisors</h2><p style="margin:6px 0 0;">Expert guidance to keep us on track toward international standards in STEM.</p></div></div>
        <div class="grid-6">
          {advisors.map((m) => (
            <div class="person">
              <div class="pf"><Img src={m.data.image} alt={m.data.name} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" widths={[200, 400]} sizes="200px" /></div>
              <div class="nm">{m.data.name}</div>
              {m.data.role && <div class="rl">{m.data.role}</div>}
              {m.data.affiliation && <div class="aff">{m.data.affiliation}</div>}
            </div>
          ))}
        </div>
      </div>

      <div class="panel">
        <div class="panel-head"><div><span class="eyebrow">Section 3 · Our Team</span><h2 style="margin-top:10px;">Organizing Team</h2><p style="margin:6px 0 0;">The core team running BdMSO operations end-to-end.</p></div></div>
        <div class="grid-6">
          {organizing.map((m) => (
            <div class="person">
              <div class="pf"><Img src={m.data.image} alt={m.data.name} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" widths={[200, 400]} sizes="200px" /></div>
              <div class="nm">{m.data.name}</div>
              {m.data.role && <div class="rl">{m.data.role}</div>}
              {m.data.affiliation && <div class="aff">{m.data.affiliation}</div>}
            </div>
          ))}
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <div><span class="eyebrow">Section 4 · Our Team</span><h2 style="margin-top:10px;">Mentors &amp; Volunteers</h2><p style="margin:6px 0 0;">The coaches and operational team driving BdMSO year-round.</p></div>
          <button class="btn btn-ghost" id="mv-toggle" type="button">View all →</button>
        </div>
        <div class="grid-6" id="mv-grid">
          {mentors.map((m) => (
            <div class="person">
              <div class="pf"><Img src={m.data.image} alt={m.data.name} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" widths={[200, 400]} sizes="200px" /></div>
              <div class="nm">{m.data.name}</div>
              {m.data.role && <div class="rl">{m.data.role}</div>}
              {m.data.affiliation && <div class="aff">{m.data.affiliation}</div>}
            </div>
          ))}
        </div>
      </div>

      <div class="panel">
        <div class="panel-head"><div><span class="eyebrow">Section 5 · Our Team</span><h2 style="margin-top:10px;">Our Alumni</h2><p style="margin:6px 0 0;">Honoring the mentors, volunteers, delegates, and leaders who have inspired the BdMSO journey.</p></div></div>
        <div class="grid-6">
          {alumni.map((m) => (
            <div class="person">
              <div class="pf"><Img src={m.data.image} alt={m.data.name} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" widths={[200, 400]} sizes="200px" /></div>
              <div class="nm">{m.data.name}</div>
              {m.data.role && <div class="rl">{m.data.role}</div>}
              {m.data.affiliation && <div class="aff">{m.data.affiliation}</div>}
            </div>
          ))}
        </div>
      </div>

    </section>

  <script is:inline>
  // ── Mentors & Volunteers rotating carousel ──────────────────────────────────
  (() => {
    const grid = document.getElementById('mv-grid');
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('.person'));
    const toggle = document.getElementById('mv-toggle');
    if (cards.length <= 6 && toggle) toggle.style.display = 'none';

    // Slots visible at each breakpoint (matches .grid-6 media queries).
    const slots = () => {
      const w = window.innerWidth;
      if (w <= 560) return 2;
      if (w <= 1000) return 3;
      return 6;
    };

    let offset = 0;
    let expanded = false;
    let timer = null;

    function render() {
      if (expanded) {
        cards.forEach(c => c.removeAttribute('data-mv-hidden'));
        return;
      }
      const n = Math.min(slots(), cards.length);
      cards.forEach(c => c.setAttribute('data-mv-hidden', ''));
      for (let i = 0; i < n; i++) {
        cards[(offset + i) % cards.length].removeAttribute('data-mv-hidden');
      }
    }

    function startRotation() {
      if (timer) return;
      timer = setInterval(() => { offset = (offset + 1) % cards.length; render(); }, 4000);
    }
    function stopRotation() {
      if (!timer) return;
      clearInterval(timer);
      timer = null;
    }

    render();
    window.addEventListener('resize', render);
    if (cards.length > 6) startRotation();

    toggle?.addEventListener('click', () => {
      expanded = !expanded;
      if (expanded) { stopRotation(); toggle.textContent = 'Show less ↑'; }
      else          { startRotation(); toggle.textContent = 'View all →'; }
      render();
    });
  })();

  document.querySelectorAll('.years button').forEach(b => b.addEventListener('click', () => {
    b.parentElement.querySelectorAll('button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const yr = b.dataset.year;
    if (!yr) return;
    document.querySelectorAll('.year-panel').forEach(p => {
      p.hidden = p.dataset.year !== yr;
      if (p.dataset.year === yr && p.dataset.blurb) {
        const blurb = document.getElementById('delegation-blurb');
        if (blurb) blurb.textContent = p.dataset.blurb;
      }
    });
  }));
  </script>
</BaseLayout>
