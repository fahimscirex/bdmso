---
// Cross-link block shared by program and blog detail pages. Renders nothing
// when there are no related items, so callers can pass an empty list freely.
interface Item {
  kicker: string;
  title: string;
  desc?: string;
  url: string;
}
interface Props {
  heading: string;
  items: Item[];
}
const { heading, items } = Astro.props;
---

{items.length > 0 && (
  <aside class="related-block">
    <div class="container">
      <h2 class="related-heading">{heading}</h2>
      <div class="related-cards">
        {items.map((it) => (
          <a class="related-card" href={it.url}>
            <span class="rc-kicker">{it.kicker}</span>
            <span class="rc-title">{it.title}</span>
            {it.desc && <span class="rc-desc">{it.desc}</span>}
          </a>
        ))}
      </div>
    </div>
  </aside>
)}

<style>
  .related-block { padding: 8px 0 80px; }
  .related-block .container { border-top: 1px solid var(--line); padding-top: 40px; }
  .related-heading { font-size: 1.3rem; margin: 0 0 18px; color: var(--navy-900); }
  .related-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    background: white;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .related-card:hover { transform: translateY(-3px); border-color: var(--navy-600); box-shadow: var(--shadow); }
  .rc-kicker { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--navy-700); }
  .rc-title { font-size: 1.02rem; font-weight: 600; color: var(--navy-900); line-height: 1.3; }
  .rc-desc { font-size: 13px; color: var(--ink-3); line-height: 1.45; }
</style>
